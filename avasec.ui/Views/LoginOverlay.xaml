<UserControl x:Class="AVASec.UI.Views.LoginOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AVASec.UI.Views"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000">

    <Border Background="{DynamicResource ThemeBackgroundBrush}" CornerRadius="16">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"/> <!-- Left Panel -->
                <ColumnDefinition Width="*"/>   <!-- Right Panel -->
            </Grid.ColumnDefinitions>

            <!-- Left Panel - Branding -->
            <Border Grid.Column="0" CornerRadius="16,0,0,16">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#2196F3" Offset="0"/>
                        <GradientStop Color="#1976D2" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <!-- Decorative circles -->
                    <Ellipse Width="300" Height="300" Fill="#1A00D4AA" Margin="-100,-50,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                    <Ellipse Width="200" Height="200" Fill="#1A3282B8" Margin="0,0,-50,-100" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                    
                    <StackPanel VerticalAlignment="Center" Margin="40">
                        <!-- Logo -->
                        <Border Width="100" Height="100" CornerRadius="50" Background="White" Opacity="0.1" Margin="0,0,0,30">
                            <TextBlock Text="⚡" FontSize="50" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        
                        <TextBlock Text="AVA Security" FontSize="36" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource Lang.Brand.Slogan}" Style="{StaticResource CaptionStyle}" FontSize="14" HorizontalAlignment="Center" Margin="0,8,0,40"/>
                        
                        <!-- Features List -->
                        <StackPanel Margin="0,20,0,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <TextBlock Text="✓" Foreground="{StaticResource AccentTealBrush}" FontSize="16" FontWeight="Bold" Margin="0,0,12,0"/>
                                <TextBlock Text="{DynamicResource Lang.Feature.Boost}" Foreground="White" FontSize="13"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <TextBlock Text="✓" Foreground="{StaticResource AccentTealBrush}" FontSize="16" FontWeight="Bold" Margin="0,0,12,0"/>
                                <TextBlock Text="{DynamicResource Lang.Feature.Malware}" Foreground="White" FontSize="13"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <TextBlock Text="✓" Foreground="{StaticResource AccentTealBrush}" FontSize="16" FontWeight="Bold" Margin="0,0,12,0"/>
                                <TextBlock Text="{DynamicResource Lang.Feature.Clean}" Foreground="White" FontSize="13"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✓" Foreground="{StaticResource AccentTealBrush}" FontSize="16" FontWeight="Bold" Margin="0,0,12,0"/>
                                <TextBlock Text="{DynamicResource Lang.Feature.Support}" Foreground="White" FontSize="13"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                    
                    <!-- Footer -->
                    <TextBlock Text="{DynamicResource Lang.Brand.Copyright}" 
                               Style="{StaticResource CaptionStyle}" 
                               VerticalAlignment="Bottom" 
                               HorizontalAlignment="Center" 
                               Margin="0,0,0,20" 
                               Opacity="0.5"/>
                </Grid>
            </Border>

            <!-- Right Panel - Login/Register Form -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Window Controls & Language -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,16,0">
                    <ComboBox x:Name="LanguageComboBox" Width="120" Margin="0,0,16,0" VerticalAlignment="Center"
                              SelectionChanged="LanguageComboBox_SelectionChanged" Style="{StaticResource {x:Static ToolBar.ComboBoxStyleKey}}">
                        <ComboBoxItem Content="Tiếng Việt" Tag="vi-VN" IsSelected="True"/>
                        <ComboBoxItem Content="English" Tag="en-US"/>
                        <ComboBoxItem Content="Song ngữ / Bilingual (VI-EN)" Tag="vi-EN"/>
                    </ComboBox>

                    <Button Style="{StaticResource IconButtonStyle}" Click="Close_Click" ToolTip="Exit Application" Foreground="{StaticResource ErrorBrush}">
                        <TextBlock Text="✕" FontSize="12"/>
                    </Button>
                </StackPanel>

                <!-- Form Content -->
                <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="50,20,50,40">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TabItem">
                                        <Border x:Name="Border" 
                                                Background="Transparent" 
                                                BorderThickness="0,0,0,2"
                                                BorderBrush="Transparent"
                                                Padding="20,12"
                                                Margin="0,0,16,0">
                                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentBlueLightBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource DarkSurfaceBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </TabControl.Resources>

                    <!-- Login Tab -->
                    <TabItem Header="{DynamicResource Lang.Login.Title}">
                        <StackPanel Margin="0,40,0,0">
                            <TextBlock Text="{DynamicResource Lang.Login.Welcome}" Style="{StaticResource Heading2Style}" Margin="0,0,0,8"/>
                            <TextBlock Text="{DynamicResource Lang.Login.Subtitle}" Style="{StaticResource CaptionStyle}" Margin="0,0,0,30"/>

                            <!-- Username Field -->
                            <TextBlock Text="{DynamicResource Lang.Login.Username}" Style="{StaticResource LabelStyle}" Margin="0,0,0,8"/>
                            <TextBlock Text="{DynamicResource Lang.Login.Username}" Style="{StaticResource LabelStyle}" Margin="0,0,0,8"/>
                            <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,20">
                                <TextBox x:Name="LoginUsernameTextBox" 
                                         Background="Transparent"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         BorderThickness="0"
                                         Padding="16,14"
                                         FontSize="14"
                                         CaretBrush="{StaticResource TextPrimaryBrush}"
                                         Text="admin"/>
                            </Border>

                            <!-- Password Field -->
                            <TextBlock Text="{DynamicResource Lang.Login.Password}" Style="{StaticResource LabelStyle}" Margin="0,0,0,8"/>
                            <TextBlock Text="{DynamicResource Lang.Login.Password}" Style="{StaticResource LabelStyle}" Margin="0,0,0,8"/>
                            <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,30">
                                <PasswordBox x:Name="LoginPasswordBox" 
                                             Background="Transparent"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             BorderThickness="0"
                                             Padding="16,14"
                                             FontSize="14"
                                             CaretBrush="{StaticResource TextPrimaryBrush}"
                                             PasswordChar="●"
                                             Password="admin"/>
                            </Border>

                            <!-- Login Button -->
                            <Button Style="{StaticResource PrimaryButtonStyle}" 
                                    Content="{DynamicResource Lang.Login.Button}" 
                                    Click="LoginButton_Click"
                                    FontSize="14"
                                    Padding="0,16">
                                <Button.Effect>
                                    <DropShadowEffect Color="#3282B8" BlurRadius="20" ShadowDepth="0" Opacity="0.4"/>
                                </Button.Effect>
                            </Button>

                            <!-- Continue as Guest -->
                            <Button Style="{StaticResource SecondaryButtonStyle}" 
                                    Content="Continue as Guest / Tiếp tục (Khách)" 
                                    Click="GuestButton_Click"
                                    FontSize="14"
                                    Padding="0,12"
                                    Margin="0,16,0,0"/>

                            <!-- Forgot Password -->
                            <TextBlock Text="{DynamicResource Lang.Login.Forgot}" 
                                       Style="{StaticResource LinkTextStyle}" 
                                       HorizontalAlignment="Center" 
                                       Margin="0,20,0,0" 
                                       Cursor="Hand"/>
                        </StackPanel>
                    </TabItem>

                    <!-- Register Tab -->
                    <TabItem Header="{DynamicResource Lang.Register.Tab}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,30,0,0">
                                <TextBlock Text="{DynamicResource Lang.Register.Title}" Style="{StaticResource Heading2Style}" Margin="0,0,0,8"/>
                                <TextBlock Text="{DynamicResource Lang.Register.Subtitle}" Style="{StaticResource CaptionStyle}" Margin="0,0,0,24"/>

                                <!-- Username Field -->
                                <TextBlock Text="{DynamicResource Lang.Login.Username}" Style="{StaticResource LabelStyle}" Margin="0,0,0,8"/>
                                <TextBlock Text="{DynamicResource Lang.Login.Username}" Style="{StaticResource LabelStyle}" Margin="0,0,0,8"/>
                                <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,16">
                                    <TextBox x:Name="RegisterUsernameTextBox" 
                                             Background="Transparent"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             BorderThickness="0"
                                             Padding="16,12"
                                             FontSize="14"
                                             CaretBrush="{StaticResource TextPrimaryBrush}"/>
                                </Border>

                                <!-- Email Field -->
                                <TextBlock Text="{DynamicResource Lang.Register.Email}" Style="{StaticResource LabelStyle}" Margin="0,0,0,8"/>
                                <TextBlock Text="{DynamicResource Lang.Register.Email}" Style="{StaticResource LabelStyle}" Margin="0,0,0,8"/>
                                <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,16">
                                    <TextBox x:Name="RegisterEmailTextBox" 
                                             Background="Transparent"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             BorderThickness="0"
                                             Padding="16,12"
                                             FontSize="14"
                                             CaretBrush="{StaticResource TextPrimaryBrush}"/>
                                </Border>

                                <!-- Password Field -->
                                <TextBlock Text="{DynamicResource Lang.Login.Password}" Style="{StaticResource LabelStyle}" Margin="0,0,0,8"/>
                                <TextBlock Text="{DynamicResource Lang.Login.Password}" Style="{StaticResource LabelStyle}" Margin="0,0,0,8"/>
                                <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,24">
                                    <PasswordBox x:Name="RegisterPasswordBox" 
                                                 Background="Transparent"
                                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                                 BorderThickness="0"
                                                 Padding="16,12"
                                                 FontSize="14"
                                                 CaretBrush="{StaticResource TextPrimaryBrush}"
                                                 PasswordChar="●"/>
                                </Border>

                                <!-- Register Button -->
                                <Button Style="{StaticResource SuccessButtonStyle}" 
                                        Content="{DynamicResource Lang.Register.Button}" 
                                        Click="RegisterButton_Click"
                                        FontSize="14"
                                        Padding="0,14"/>

                                <!-- Benefits Box -->
                                <Border Background="{DynamicResource SelectedItemBgBrush}" CornerRadius="8" Padding="16" Margin="0,24,0,0">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource Lang.Register.Benefits}" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" Margin="0,0,0,12"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <TextBlock Text="✓" Foreground="{StaticResource SuccessBrush}" FontWeight="Bold" Margin="0,0,8,0"/>
                                            <TextBlock Text="{DynamicResource Lang.Register.Benefit1}" Style="{StaticResource CaptionStyle}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <TextBlock Text="✓" Foreground="{StaticResource SuccessBrush}" FontWeight="Bold" Margin="0,0,8,0"/>
                                            <TextBlock Text="{DynamicResource Lang.Register.Benefit2}" Style="{StaticResource CaptionStyle}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="✓" Foreground="{StaticResource SuccessBrush}" FontWeight="Bold" Margin="0,0,8,0"/>
                                            <TextBlock Text="{DynamicResource Lang.Register.Benefit3}" Style="{StaticResource CaptionStyle}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Grid>
        </Grid>
    </Border>
</UserControl>
