<Window x:Class="AVASec.UI.Views.ToolboxWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AVASec.UI.Views"
        Title="AVA Security Toolbox" 
        Height="650" Width="950"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A2E"
        AllowsTransparency="True" WindowStyle="None">

    <Window.Resources>
        <!-- Dark Theme Colors -->
        <SolidColorBrush x:Key="DarkBg" Color="#1A1A2E"/>
        <SolidColorBrush x:Key="DarkSurface" Color="#16213E"/>
        <SolidColorBrush x:Key="DarkCard" Color="#1F2940"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#0F4C75"/>
        <SolidColorBrush x:Key="AccentOrange" Color="#FF6B35"/>
        <SolidColorBrush x:Key="TextWhite" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextGray" Color="#8E99A4"/>
        <SolidColorBrush x:Key="BorderColor" Color="#2D3A4F"/>
        
        <!-- Tab Button Style -->
        <Style x:Key="ToolboxTab" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextGray}"/>
            <Setter Property="Padding" Value="25,12"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource AccentBlue}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2D3A4F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Tool Card Style -->
        <Style x:Key="ToolCard" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2D3A4F"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Badge Styles -->
        <Style x:Key="HotBadge" TargetType="Border">
            <Setter Property="Background" Value="#FF6B35"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Margin" Value="5,0,0,0"/>
        </Style>
        
        <Style x:Key="ProBadge" TargetType="Border">
            <Setter Property="Background" Value="#4A90D9"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Margin" Value="5,0,0,0"/>
        </Style>
        
        <Style x:Key="NewBadge" TargetType="Border">
            <Setter Property="Background" Value="#00D4AA"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Margin" Value="5,0,0,0"/>
        </Style>
    </Window.Resources>

    <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="8">
        <Grid Background="{StaticResource DarkBg}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Title Bar -->
                <RowDefinition Height="Auto"/>  <!-- Tabs -->
                <RowDefinition Height="Auto"/>  <!-- Favorites hint -->
                <RowDefinition Height="*"/>     <!-- Tools Grid -->
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="{StaticResource DarkSurface}" 
                    CornerRadius="8,8,0,0" MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid Margin="15,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="☰" Foreground="{StaticResource TextGray}" FontSize="16" 
                                   VerticalAlignment="Center" Margin="0,0,15,0"/>
                        <TextBlock Text="Hộp công cụ / AVA Security Toolbox" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextWhite}" VerticalAlignment="Center"/>
                        <TextBlock Text=" Pro" FontSize="12" Foreground="{StaticResource AccentOrange}" 
                                   VerticalAlignment="Center" Margin="5,0,0,0"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="👤" x:Name="UserButton" Style="{DynamicResource IconButtonStyle}" Width="36" Height="36" Click="UserButton_Click" Foreground="{StaticResource TextGray}" ToolTip="Login / Đăng nhập" WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button Content="💬" x:Name="ChatToggleButton" Style="{DynamicResource IconButtonStyle}" Width="36" Height="36" Click="ChatToggle_Click" Foreground="{StaticResource TextGray}" Margin="0,0,5,0" ToolTip="Support Chat (Dashboard) / Hỗ trợ Chat" WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button Content="⚙" Style="{DynamicResource IconButtonStyle}" Width="36" Height="36" Click="Settings_Click" Foreground="{StaticResource TextGray}" WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button Content="─" Style="{DynamicResource IconButtonStyle}" Width="36" Height="36" Click="MinimizeButton_Click" Foreground="{StaticResource TextGray}" ToolTip="Minimize to Taskbar / Thu nhỏ xuống thanh tác vụ" WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button Content="➘" Style="{DynamicResource IconButtonStyle}" Width="36" Height="36" Click="TrayButton_Click" Foreground="{StaticResource TextGray}" ToolTip="Hide / Ẩn" WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button Content="✕" Style="{DynamicResource IconButtonStyle}" Width="36" Height="36" Click="CloseButton_Click" Foreground="{StaticResource TextGray}" ToolTip="Close / Đóng" WindowChrome.IsHitTestVisibleInChrome="True"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Tab Bar -->
            <Border Grid.Row="1" Background="{StaticResource DarkSurface}" BorderBrush="{StaticResource BorderColor}" 
                    BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal">
                    <RadioButton Content="Dọn dẹp &amp; Tối ưu / Clean &amp; Optimize" Style="{StaticResource ToolboxTab}" 
                                 GroupName="MainTabs" Checked="Tab_Checked"/>
                    <RadioButton Content="Tăng tốc / Speed Up" Style="{StaticResource ToolboxTab}" 
                                 GroupName="MainTabs" Checked="Tab_Checked"/>
                    <RadioButton Content="Bảo vệ / Protect" Style="{StaticResource ToolboxTab}" 
                                 GroupName="MainTabs" Checked="Tab_Checked"/>
                    <RadioButton x:Name="ToolboxTab" Content="Hộp công cụ / Toolbox" Style="{StaticResource ToolboxTab}" 
                                 GroupName="MainTabs" IsChecked="True" Checked="Tab_Checked"/>
                    <RadioButton Content="Hành động / Action Center" Style="{StaticResource ToolboxTab}" 
                                 GroupName="MainTabs" Checked="Tab_Checked" Tag="ActionCenters"/>
                    <RadioButton x:Name="PluginsTab" Content="Tiện ích mở rộng / Plugins" Style="{StaticResource ToolboxTab}" 
                                 GroupName="MainTabs" Checked="Tab_Checked" Tag="Plugins"/>
                </StackPanel>
            </Border>

            <!-- Favorites Hint -->
            <Border Grid.Row="2" Padding="20,12" Background="{StaticResource DarkSurface}"
                    BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Yêu thích / Favorites:" Foreground="{StaticResource TextGray}" FontSize="12"/>
                    <TextBlock Text=" Nhấn vào biểu tượng trái tim để thêm công cụ yêu thích / Click the heart icon to add your favorite tools" 
                               Foreground="{StaticResource TextGray}" FontSize="12" Opacity="0.7"/>
                </StackPanel>
            </Border>

            <!-- Tools Grid -->
            <ScrollViewer x:Name="BuiltInToolsPanel" Grid.Row="3" VerticalScrollBarVisibility="Auto" Padding="15,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Column 1: AVA Security Tools -->
                    <StackPanel Grid.Column="0" Margin="5">
                        <TextBlock Text="Công cụ AVA Security / AVA Security Tools ⓘ" Foreground="{StaticResource TextGray}" 
                                   FontSize="11" Margin="10,5,0,10"/>
                        
                        <Border Style="{StaticResource ToolCard}" MouseLeftButtonDown="Tool_Click" Tag="Uninstaller">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#E74C3C" Margin="0,0,12,0">
                                    <TextBlock Text="U" Foreground="White" FontWeight="Bold" FontSize="18"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Gỡ cài đặt / Uninstaller" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        
                        <Border Style="{StaticResource ToolCard}" MouseLeftButtonDown="Tool_Click" Tag="DriverBooster">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#E67E22" Margin="0,0,12,0">
                                    <TextBlock Text="⚡" Foreground="White" FontSize="18"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Cập nhật Driver / Driver Booster" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        
                        <Border Style="{StaticResource ToolCard}" MouseLeftButtonDown="Tool_Click" Tag="SmartDefrag">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#3498DB" Margin="0,0,12,0">
                                    <TextBlock Text="▣" Foreground="White" FontSize="18"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Smart Defrag" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        
                        <Border Style="{StaticResource ToolCard}" MouseLeftButtonDown="Tool_Click" Tag="MalwareFighter">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#9B59B6" Margin="0,0,12,0">
                                    <TextBlock Text="🛡" Foreground="White" FontSize="16"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Chống Mã độc / Malware Fighter" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Column 2: System Optimize -->
                    <StackPanel Grid.Column="1" Margin="5">
                        <TextBlock Text="Tối ưu Hệ thống / System Optimize" Foreground="{StaticResource TextGray}" 
                                   FontSize="11" Margin="10,5,0,10"/>
                        
                        <Border Style="{StaticResource ToolCard}" MouseLeftButtonDown="Tool_Click" Tag="StartupManager">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#00D4AA" Margin="0,0,12,0">
                                    <TextBlock Text="⏱" Foreground="White" FontSize="16"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Quản lý Khởi động / Startup Manager" Foreground="White" FontSize="13"/>
                                    <Border Style="{StaticResource HotBadge}" HorizontalAlignment="Left" Margin="0,3,0,0">
                                        <TextBlock Text="Hot" Foreground="White" FontSize="9"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        
                        <Border Style="{StaticResource ToolCard}" MouseLeftButtonDown="Tool_Click" Tag="SmartRAM">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#4A90D9" Margin="0,0,12,0">
                                    <TextBlock Text="💾" Foreground="White" FontSize="16"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Smart RAM" Foreground="White" FontSize="13"/>
                                    <Border Style="{StaticResource ProBadge}" HorizontalAlignment="Left" Margin="0,3,0,0">
                                        <TextBlock Text="Pro" Foreground="White" FontSize="9"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        
                        <Border Style="{StaticResource ToolCard}" MouseLeftButtonDown="Tool_Click" Tag="InternetBooster">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#E74C3C" Margin="0,0,12,0">
                                    <TextBlock Text="🌐" Foreground="White" FontSize="16"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Tăng tốc Internet / Internet Booster" Foreground="White" FontSize="13"/>
                                    <Border Style="{StaticResource ProBadge}" HorizontalAlignment="Left" Margin="0,3,0,0">
                                        <TextBlock Text="Pro" Foreground="White" FontSize="9"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        
                        <Border Style="{StaticResource ToolCard}" MouseLeftButtonDown="Tool_Click" Tag="AutoShutdown">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#F39C12" Margin="0,0,12,0">
                                    <TextBlock Text="⏻" Foreground="White" FontSize="18"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Tự động Tắt / Auto Shutdown" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        
                        <Border Style="{StaticResource ToolCard}" MouseLeftButtonDown="Tool_Click" Tag="ProgramDeactivator">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#1ABC9C" Margin="0,0,12,0">
                                    <TextBlock Text="📦" Foreground="White" FontSize="16"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Tắt Ứng dụng / Program Deactivator" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Column 3: Security & Repair -->
                    <StackPanel Grid.Column="2" Margin="5">
                        <TextBlock Text="Bảo mật &amp; Sửa lỗi / Security &amp; Repair" Foreground="{StaticResource TextGray}" 
                                   FontSize="11" Margin="10,5,0,10"/>
                        
                        <Border Style="{StaticResource ToolCard}" MouseLeftButtonDown="Tool_Click" Tag="WinFix">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#3498DB" Margin="0,0,12,0">
                                    <TextBlock Text="🔧" Foreground="White" FontSize="16"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Sửa lỗi Win / Win Fix" Foreground="White" FontSize="13"/>
                                    <Border Style="{StaticResource ProBadge}" HorizontalAlignment="Left" Margin="0,3,0,0">
                                        <TextBlock Text="Pro" Foreground="White" FontSize="9"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        
                        <Border Style="{StaticResource ToolCard}" MouseLeftButtonDown="Tool_Click" Tag="MyWin10">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#00D4AA" Margin="0,0,12,0">
                                    <TextBlock Text="🪟" Foreground="White" FontSize="16"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="MyWin10/11" Foreground="White" FontSize="13"/>
                                    <Border Style="{StaticResource HotBadge}" HorizontalAlignment="Left" Margin="0,3,0,0">
                                        <TextBlock Text="Hot" Foreground="White" FontSize="9"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        
                        <Border Style="{StaticResource ToolCard}" MouseLeftButtonDown="Tool_Click" Tag="DiskDoctor">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#9B59B6" Margin="0,0,12,0">
                                    <TextBlock Text="💿" Foreground="White" FontSize="16"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Bác sĩ Ổ đĩa / Disk Doctor" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        
                        <Border Style="{StaticResource ToolCard}" MouseLeftButtonDown="Tool_Click" Tag="Undelete">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#E74C3C" Margin="0,0,12,0">
                                    <TextBlock Text="♻" Foreground="White" FontSize="18"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Khôi phục / Undelete" Foreground="White" FontSize="13"/>
                                    <Border Style="{StaticResource NewBadge}" HorizontalAlignment="Left" Margin="0,3,0,0">
                                        <TextBlock Text="New" Foreground="White" FontSize="9"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        
                        <Border Style="{StaticResource ToolCard}" MouseLeftButtonDown="Tool_Click" Tag="FileShredder">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#34495E" Margin="0,0,12,0">
                                    <TextBlock Text="🗑" Foreground="White" FontSize="16"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Xóa vĩnh viễn / File Shredder" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Column 4: System Clean -->
                    <StackPanel Grid.Column="3" Margin="5">
                        <TextBlock Text="Dọn dẹp Hệ thống / System Clean" Foreground="{StaticResource TextGray}" 
                                   FontSize="11" Margin="10,5,0,10"/>
                        
                        <Border Style="{StaticResource ToolCard}" MouseLeftButtonDown="Tool_Click" Tag="RegistryCleaner">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#3498DB" Margin="0,0,12,0">
                                    <TextBlock Text="📋" Foreground="White" FontSize="16"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Dọn Registry / Registry Cleaner" Foreground="White" FontSize="13"/>
                                    <Border Style="{StaticResource ProBadge}" HorizontalAlignment="Left" Margin="0,3,0,0">
                                        <TextBlock Text="Pro" Foreground="White" FontSize="9"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        
                        <Border Style="{StaticResource ToolCard}" MouseLeftButtonDown="Tool_Click" Tag="DiskCleaner">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#00D4AA" Margin="0,0,12,0">
                                    <TextBlock Text="🧹" Foreground="White" FontSize="16"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Dọn dẹp Đĩa / Disk Cleaner" Foreground="White" FontSize="13"/>
                                    <Border Style="{StaticResource ProBadge}" HorizontalAlignment="Left" Margin="0,3,0,0">
                                        <TextBlock Text="Pro" Foreground="White" FontSize="9"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        
                        <Border Style="{StaticResource ToolCard}" MouseLeftButtonDown="Tool_Click" Tag="LargeFileFinder">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#E74C3C" Margin="0,0,12,0">
                                    <TextBlock Text="📁" Foreground="White" FontSize="16"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Tìm file lớn / Large File Finder" Foreground="White" FontSize="13"/>
                                    <Border Style="{StaticResource HotBadge}" HorizontalAlignment="Left" Margin="0,3,0,0">
                                        <TextBlock Text="Hot" Foreground="White" FontSize="9"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        
                        <Border Style="{StaticResource ToolCard}" MouseLeftButtonDown="Tool_Click" Tag="EmptyFolderScanner">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#95A5A6" Margin="0,0,12,0">
                                    <TextBlock Text="📂" Foreground="White" FontSize="16"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Quét thư mục trống / Empty Folder Scanner" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        
                        <Border Style="{StaticResource ToolCard}" MouseLeftButtonDown="Tool_Click" Tag="ShortcutFixer">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#1ABC9C" Margin="0,0,12,0">
                                    <TextBlock Text="🔗" Foreground="White" FontSize="16"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Sửa lỗi Shortcut / Shortcut Fixer" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </ScrollViewer>

                <!-- Plugins Panel -->
                <Grid x:Name="PluginsPanel" Grid.Row="3" Visibility="Collapsed" Margin="15,10">
                    <local:CyberToolboxView />
                </Grid>
        </Grid>
    </Border>
</Window>
