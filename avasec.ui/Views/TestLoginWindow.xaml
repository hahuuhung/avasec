<Window x:Class="AVASec.UI.Views.TestLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Test - Login Visibility" 
        Height="400" Width="500"
        Background="#1E1B4B"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="50">
        <StackPanel>
            <TextBlock Text="TEST - Kiểm tra hiển thị text" 
                      Foreground="White" 
                      FontSize="20" 
                      FontWeight="Bold"
                      Margin="0,0,0,30"/>

            <!-- Test 1: Simple TextBox -->
            <TextBlock Text="Test 1: TextBox đơn giản" 
                      Foreground="White" 
                      FontSize="14"
                      Margin="0,0,0,10"/>
            <TextBox Text="Nhập username ở đây"
                     Background="#0F172A"
                     Foreground="White"
                     BorderBrush="#6366F1"
                     BorderThickness="2"
                     Padding="10"
                     FontSize="16"
                     Height="45"
                     Margin="0,0,0,20"/>

            <!-- Test 2: PasswordBox -->
            <TextBlock Text="Test 2: PasswordBox" 
                      Foreground="White" 
                      FontSize="14"
                      Margin="0,0,0,10"/>
            <PasswordBox Password="test123"
                        Background="#0F172A"
                        Foreground="White"
                        BorderBrush="#6366F1"
                        BorderThickness="2"
                        Padding="10"
                        FontSize="16"
                        PasswordChar="●"
                        Height="45"
                        Margin="0,0,0,20"/>

            <TextBlock Text="✅ Nếu thấy text trắng ở trên = OK!" 
                      Foreground="#10B981" 
                      FontSize="14"
                      TextAlignment="Center"
                      FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
