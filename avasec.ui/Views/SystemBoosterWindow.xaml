<Window x:Class="AVASec.UI.Views.SystemBoosterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AVASec.UI.Views"
        mc:Ignorable="d"
        Title="System Booster Pro" Height="650" Width="950"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">
    
    <Window.Resources>
        <Style x:Key="CategoryBtnStyle" TargetType="RadioButton">
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="Transparent" CornerRadius="8" Margin="10,2">
                            <StackPanel Orientation="Horizontal" Margin="15,0">
                                <TextBlock x:Name="icon" Text="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" 
                                           FontSize="18" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="#64748B"/> <!-- Slate 500 -->
                                <ContentPresenter VerticalAlignment="Center" TextElement.Foreground="#475569"/> <!-- Slate 600 -->
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#EFF6FF"/> <!-- Blue 50 -->
                                <Setter TargetName="icon" Property="Foreground" Value="{DynamicResource AccentBlueBrush}"/>
                                <Setter Property="Foreground" Value="#0F172A"/> <!-- Slate 900 -->
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F1F5F9"/> <!-- Slate 100 -->
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OptCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF"/> <!-- White -->
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/> <!-- Slate 200 -->
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="5" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Main Window Background: Slate 50 -->
    <Border Background="#F8FAFC" CornerRadius="16" BorderBrush="#E2E8F0" BorderThickness="1.5">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/> <!-- Sidebar -->
                <ColumnDefinition Width="*"/>   <!-- Main Content -->
            </Grid.ColumnDefinitions>

            <!-- Sidebar Background: White -->
            <Border Grid.Column="0" Background="#FFFFFF" CornerRadius="16,0,0,16" BorderBrush="#E2E8F0" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- App Title / Logo -->
                    <StackPanel Grid.Row="0" Margin="25,30,25,40" Orientation="Horizontal">
                        <Border Width="36" Height="36" Background="{DynamicResource AccentBlueBrush}" CornerRadius="8" Margin="0,0,12,0">
                            <TextBlock Text="🚀" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20" Foreground="White"/>
                        </Border>
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Lang.Tools.SystemBooster}" Foreground="#0F172A" FontSize="18" FontWeight="Bold"/>
                            <TextBlock Text="Professional Edition" Foreground="#64748B" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Navigation -->
                    <StackPanel Grid.Row="1">
                        <RadioButton Content="{DynamicResource Lang.Tools.SystemBooster.Cat.Desktop}" Tag="💻" IsChecked="True" Style="{StaticResource CategoryBtnStyle}" Checked="Category_Checked"/>
                        <RadioButton Content="{DynamicResource Lang.Tools.SystemBooster.Cat.Network}" Tag="🌐" Style="{StaticResource CategoryBtnStyle}" Checked="Category_Checked"/>
                        <RadioButton Content="{DynamicResource Lang.Tools.SystemBooster.Cat.Power}" Tag="⚡" Style="{StaticResource CategoryBtnStyle}" Checked="Category_Checked"/>
                        <RadioButton Content="{DynamicResource Lang.Tools.SystemBooster.Cat.Stability}" Tag="🧹" Style="{StaticResource CategoryBtnStyle}" Checked="Category_Checked"/>
                        <RadioButton x:Name="BenchmarkTabBtn" Content="Performance Benchmark" Tag="📊" Style="{StaticResource CategoryBtnStyle}" Checked="Category_Checked"/>
                    </StackPanel>

                    <!-- Footer Info -->
                    <Border Grid.Row="2" Margin="20" Padding="15" Background="#F1F5F9" CornerRadius="10">
                        <StackPanel>
                            <TextBlock Text="Protection Level" Foreground="#64748B" FontSize="11" Margin="0,0,0,5"/>
                            <TextBlock Text="ULTRA" Foreground="{DynamicResource AccentBlueBrush}" FontSize="14" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Main Content Area -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Header -->
                    <RowDefinition Height="*"/>    <!-- Scrollable Content -->
                    <RowDefinition Height="Auto"/> <!-- Status/Progress -->
                    <RowDefinition Height="Auto"/> <!-- Footer -->
                </Grid.RowDefinitions>

                <!-- Header Actions -->
                <Border Grid.Row="0" Padding="30,25" Background="Transparent">
                    <Grid>
                        <StackPanel>
                            <TextBlock x:Name="ActiveTabTitle" Text="{DynamicResource Lang.Tools.SystemBooster.Header.Desktop}" FontSize="24" FontWeight="Bold" Foreground="#0F172A"/>
                            <TextBlock x:Name="ActiveTabDesc" Text="{DynamicResource Lang.Tools.SystemBooster.Header.DesktopDesc}" Foreground="#64748B" FontSize="13" Margin="0,4,0,0"/>
                        </StackPanel>
                        <!-- Close Button: Darker for visibility on light bg -->
                        <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top" 
                                Width="30" Height="30" Background="Transparent" BorderThickness="0" Foreground="#64748B" FontSize="16" FontWeight="Bold"
                                Click="CloseButton_Click" WindowChrome.IsHitTestVisibleInChrome="True">
                             <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="15">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#E2E8F0"/>
                                            <Setter Property="Foreground" Value="#EF4444"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <!-- Content Panels -->
                <ScrollViewer Grid.Row="1" Margin="30,0,30,20" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="OptimizersList">
                        <!-- Desktop Category Content (Default) -->
                        <Border x:Name="DesktopPanel" Visibility="Visible">
                            <StackPanel>
                                <Border Style="{StaticResource OptCardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="✨" FontSize="24" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{DynamicResource Lang.Tools.SystemBooster.Visuals.Title}" Foreground="#0F172A" FontSize="15" FontWeight="SemiBold"/>
                                            <TextBlock Text="{DynamicResource Lang.Tools.SystemBooster.Visuals.Desc}" Foreground="#64748B" FontSize="12" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <CheckBox x:Name="CheckVisualsV2" Grid.Column="2" IsChecked="True" VerticalAlignment="Center">
                                            <CheckBox.LayoutTransform>
                                                <ScaleTransform ScaleX="1.3" ScaleY="1.3"/>
                                            </CheckBox.LayoutTransform>
                                        </CheckBox>
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource OptCardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="🔍" FontSize="24" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{DynamicResource Lang.Tools.SystemBooster.Telemetry.Title}" Foreground="#0F172A" FontSize="15" FontWeight="SemiBold"/>
                                            <TextBlock Text="{DynamicResource Lang.Tools.SystemBooster.Telemetry.Desc}" Foreground="#64748B" FontSize="12" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <CheckBox x:Name="CheckTelemetryV2" Grid.Column="2" IsChecked="True" VerticalAlignment="Center">
                                             <CheckBox.LayoutTransform>
                                                <ScaleTransform ScaleX="1.3" ScaleY="1.3"/>
                                            </CheckBox.LayoutTransform>
                                        </CheckBox>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Network Category Content -->
                        <Border x:Name="NetworkPanel" Visibility="Collapsed">
                            <StackPanel>
                                <Border Style="{StaticResource OptCardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="🏎️" FontSize="24" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{DynamicResource Lang.Tools.SystemBooster.Net.Title}" Foreground="#0F172A" FontSize="15" FontWeight="SemiBold"/>
                                            <TextBlock Text="{DynamicResource Lang.Tools.SystemBooster.Net.Desc}" Foreground="#64748B" FontSize="12" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <CheckBox x:Name="CheckNetworkV2" Grid.Column="2" IsChecked="True" VerticalAlignment="Center">
                                            <CheckBox.LayoutTransform>
                                                <ScaleTransform ScaleX="1.3" ScaleY="1.3"/>
                                            </CheckBox.LayoutTransform>
                                        </CheckBox>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Power Category Content -->
                        <Border x:Name="PowerPanel" Visibility="Collapsed">
                            <StackPanel>
                                <Border Style="{StaticResource OptCardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="😴" FontSize="24" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{DynamicResource Lang.Tools.SystemBooster.Sleep.Title}" Foreground="#0F172A" FontSize="15" FontWeight="SemiBold"/>
                                            <TextBlock Text="{DynamicResource Lang.Tools.SystemBooster.Sleep.Desc}" Foreground="#64748B" FontSize="12" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <CheckBox x:Name="CheckSleepV2" Grid.Column="2" IsChecked="True" VerticalAlignment="Center">
                                            <CheckBox.LayoutTransform>
                                                <ScaleTransform ScaleX="1.3" ScaleY="1.3"/>
                                            </CheckBox.LayoutTransform>
                                        </CheckBox>
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource OptCardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="🐻" FontSize="24" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{DynamicResource Lang.Tools.SystemBooster.Hiber.Title}" Foreground="#0F172A" FontSize="15" FontWeight="SemiBold"/>
                                            <TextBlock Text="{DynamicResource Lang.Tools.SystemBooster.Hiber.Desc}" Foreground="#64748B" FontSize="12" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <CheckBox x:Name="CheckHiberV2" Grid.Column="2" IsChecked="True" VerticalAlignment="Center">
                                            <CheckBox.LayoutTransform>
                                                <ScaleTransform ScaleX="1.3" ScaleY="1.3"/>
                                            </CheckBox.LayoutTransform>
                                        </CheckBox>
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource OptCardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="🔥" FontSize="24" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{DynamicResource Lang.Tools.SystemBooster.Power.Title}" Foreground="#0F172A" FontSize="15" FontWeight="SemiBold"/>
                                            <TextBlock Text="{DynamicResource Lang.Tools.SystemBooster.Power.Desc}" Foreground="#64748B" FontSize="12" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <CheckBox x:Name="CheckHighPerfV2" Grid.Column="2" IsChecked="True" VerticalAlignment="Center">
                                            <CheckBox.LayoutTransform>
                                                <ScaleTransform ScaleX="1.3" ScaleY="1.3"/>
                                            </CheckBox.LayoutTransform>
                                        </CheckBox>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Cleanup Category Content -->
                        <Border x:Name="CleanupPanel" Visibility="Collapsed">
                            <StackPanel>
                                <Border Style="{StaticResource OptCardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="🗑️" FontSize="24" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{DynamicResource Lang.Tools.SystemBooster.Temp.Title}" Foreground="#0F172A" FontSize="15" FontWeight="SemiBold"/>
                                            <TextBlock Text="{DynamicResource Lang.Tools.SystemBooster.Temp.Desc}" Foreground="#64748B" FontSize="12" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <CheckBox x:Name="CheckTempFilesV2" Grid.Column="2" IsChecked="True" VerticalAlignment="Center">
                                            <CheckBox.LayoutTransform>
                                                <ScaleTransform ScaleX="1.3" ScaleY="1.3"/>
                                            </CheckBox.LayoutTransform>
                                        </CheckBox>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Benchmark Category Content -->
                        <Border x:Name="BenchmarkPanel" Visibility="Collapsed">
                            <local:BenchmarkView x:Name="BoosterBenchmarkView" Height="520"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Status Panel -->
                <Border Grid.Row="2" Margin="30,0,30,20" Padding="15" Background="#FFFFFF" CornerRadius="8" Visibility="Collapsed" x:Name="StatusPanel" BorderBrush="#E2E8F0" BorderThickness="1">
                    <Grid>
                        <ProgressBar x:Name="BoostProgressV2" Height="6" VerticalAlignment="Top" Background="#F1F5F9" Foreground="{DynamicResource AccentBlueBrush}" BorderThickness="0"/>
                        <TextBlock x:Name="StatusTextV2" Text="Ready to boost..." Margin="0,15,0,0" Foreground="#64748B" FontSize="12"/>
                        <TextBlock x:Name="ProgressPercentText" Text="0%" HorizontalAlignment="Right" VerticalAlignment="Bottom" Foreground="#0F172A" FontSize="12" FontWeight="SemiBold"/>
                    </Grid>
                </Border>

                <!-- Footer -->
                <Border Grid.Row="3" Padding="30,25" Background="#F8FAFC" CornerRadius="0,0,16,0" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
                    <Grid>
                        <TextBlock Text="All changes are fully reversible." Foreground="#94A3B8" VerticalAlignment="Center" FontSize="12"/>
                        <Button x:Name="BoostBtnV2" Content="{DynamicResource Lang.Tools.SystemBooster.BtnOptimize}" Click="BoostButton_Click" HorizontalAlignment="Right" Width="200" Height="48" Style="{DynamicResource PrimaryButtonStyle}" FontSize="14" FontWeight="Bold"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="60" ResizeBorderThickness="5" GlassFrameThickness="0" CornerRadius="16"/>
    </WindowChrome.WindowChrome>
</Window>
