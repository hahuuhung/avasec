<Window x:Class="AVASec.UI.Views.VirusScannerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Trình Quét Virus" Height="600" Width="900"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        AllowsTransparency="True" WindowStyle="None"
        Background="Transparent">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Colors.xaml"/>
                <ResourceDictionary Source="/Resources/ButtonStyles.xaml"/>
                <ResourceDictionary Source="/Resources/Animations.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="{DynamicResource BackgroundDarkBrush}" CornerRadius="12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/> <!-- Header -->
                <RowDefinition Height="Auto"/> <!-- Scan Options -->
                <RowDefinition Height="*"/> <!-- Main Content (Progress/Results) -->
                <RowDefinition Height="60"/> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0">
                <TextBlock Text="{DynamicResource Lang.Tools.VirusScan}" FontSize="20" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" Margin="20,0,0,0"/>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0">
                    <Button Content="🛡 Cách ly" Click="OpenQuarantine_Click" Style="{DynamicResource SecondaryButtonStyle}" Margin="0,0,10,0" Padding="10,5"/>
                    <Button Content="👤" x:Name="UserButton" Style="{DynamicResource IconButtonStyle}" Width="36" Height="36" Click="UserButton_Click" Foreground="White" ToolTip="Login / Đăng nhập"/>
                    <Button Content="💬" x:Name="ChatToggleButton" Style="{DynamicResource IconButtonStyle}" Width="36" Height="36" Click="ChatToggle_Click" Foreground="White" Margin="0,0,5,0" ToolTip="Support Chat (Dashboard) / Hỗ trợ Chat"/>
                    <Button Content="⚙" Style="{DynamicResource IconButtonStyle}" Width="36" Height="36" Click="Settings_Click" Foreground="White"/>
                    <Button Content="☰" Style="{DynamicResource IconButtonStyle}" Width="36" Height="36" Click="Toolbox_Click" Foreground="White"/>
                    <Button Content="─" Style="{DynamicResource IconButtonStyle}" Width="36" Height="36" Click="MinimizeButton_Click" Foreground="White" ToolTip="Minimize to Taskbar / Thu nhỏ xuống thanh tác vụ"/>
                    <Button Content="➘" Style="{DynamicResource IconButtonStyle}" Width="36" Height="36" Click="TrayButton_Click" Foreground="White" ToolTip="Hide / Ẩn"/>
                    <Button Content="✕" Style="{DynamicResource IconButtonStyle}" Width="36" Height="36" Click="CloseButton_Click" Foreground="White" ToolTip="Close / Đóng"/>
                </StackPanel>
            </Grid>

            <!-- Scan Options -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,20">
                <RadioButton x:Name="RadioQuick" Content="Quét nhanh" GroupName="ScanMode" IsChecked="True" 
                             Style="{DynamicResource ToggleButtonStyle}" Margin="5" Tag="Quick"/>
                <RadioButton x:Name="RadioFull" Content="Quét toàn bộ" GroupName="ScanMode" 
                             Style="{DynamicResource ToggleButtonStyle}" Margin="5" Tag="Full"/>
                <RadioButton x:Name="RadioCustom" Content="Quét tùy chỉnh" GroupName="ScanMode" 
                             Style="{DynamicResource ToggleButtonStyle}" Margin="5" Tag="Custom"/>
                
                <Border Width="1" Height="20" Background="#3E3E4E" Margin="10,0"/>
                
                <CheckBox x:Name="CheckBackground" Content="Background / Nền" Foreground="#BBBBBB" 
                          VerticalAlignment="Center" Margin="5,0,0,0"/>
            </StackPanel>

            <!-- Main Content Area -->
            <Grid Grid.Row="2" Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <!-- Scanning View -->
                <Grid x:Name="ScanningPanel" Grid.Column="0" Visibility="Visible">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Grid Width="220" Height="220">
                             <Ellipse Stroke="{DynamicResource CyanBrush}" StrokeThickness="1" Opacity="0.3" Margin="-10"/>
                             
                             <Ellipse Stroke="{DynamicResource SurfaceBrush}" StrokeThickness="12"/>
                             <Ellipse x:Name="ProgressRing" Stroke="{DynamicResource CyanBrush}" StrokeThickness="12" 
                                      StrokeDashArray="80 100" RenderTransformOrigin="0.5,0.5">
                                 <Ellipse.RenderTransform>
                                     <RotateTransform x:Name="SpinnerTransform" Angle="0"/>
                                 </Ellipse.RenderTransform>
                             </Ellipse>
                             
                             <StackPanel VerticalAlignment="Center">
                                 <TextBlock x:Name="ProgressPercentText" Text="0%" FontSize="36" FontWeight="Bold" 
                                            Foreground="{DynamicResource CyanBrush}" HorizontalAlignment="Center"/>
                                 <TextBlock Text="SCANNING" FontSize="10" FontWeight="SemiBold" 
                                            Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                             </StackPanel>
                        </Grid>

                        <TextBlock x:Name="CurrentStatusText" Text="Hệ thống đang được bảo vệ / Ready to protect" 
                                   Foreground="{DynamicResource CyanBrush}" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Margin="0,30,0,5"/>
                        <TextBlock x:Name="CurrentFileText" Text="..." Foreground="{DynamicResource TextMutedBrush}" 
                                   HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="450" FontSize="11"/>
                    </StackPanel>
                </Grid>

                <!-- Right Sidebar: Scan Stages -->
                <Border Grid.Column="1" Background="{DynamicResource CardDarkBrush}" CornerRadius="12" Margin="10,0,0,0" Padding="15">
                    <StackPanel>
                        <TextBlock Text="CẤP ĐỘ BẢO MẬT / SECURITY LEVELS" Foreground="White" FontSize="12" FontWeight="Bold" Margin="0,0,0,15"/>
                        
                        <!-- Stage 1 -->
                        <Grid Margin="0,5">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="Stage1Icon" Width="10" Height="10" Fill="{DynamicResource CyanBrush}" Margin="0,0,10,0"/>
                                <TextBlock Text="Hash Verification" Foreground="White" FontSize="13"/>
                            </StackPanel>
                            <TextBlock x:Name="Stage1Status" Text="Pending" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Right" FontSize="12"/>
                        </Grid>

                        <!-- Stage 2 -->
                        <Grid Margin="0,10">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="Stage2Icon" Width="10" Height="10" Fill="{DynamicResource SurfaceBrush}" Margin="0,0,10,0"/>
                                <TextBlock Text="Aho-Corasick Scan" Foreground="White" FontSize="13"/>
                            </StackPanel>
                            <TextBlock x:Name="Stage2Status" Text="Wait..." Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Right" FontSize="12"/>
                        </Grid>

                        <!-- Stage 3 -->
                        <Grid Margin="0,10">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="Stage3Icon" Width="10" Height="10" Fill="{DynamicResource SurfaceBrush}" Margin="0,0,10,0"/>
                                <TextBlock Text="AI Deep Analysis" Foreground="White" FontSize="13"/>
                            </StackPanel>
                            <TextBlock x:Name="Stage3Status" Text="Wait..." Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Right" FontSize="12"/>
                        </Grid>

                        <!-- Stage 4 -->
                        <Grid Margin="0,10">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="Stage4Icon" Width="10" Height="10" Fill="{DynamicResource SurfaceBrush}" Margin="0,0,10,0"/>
                                <TextBlock Text="Cloud Reputation" Foreground="White" FontSize="13"/>
                            </StackPanel>
                            <TextBlock x:Name="Stage4Status" Text="Wait..." Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Right" FontSize="12"/>
                        </Grid>

                        <Separator Background="{DynamicResource BorderBrush}" Margin="0,15"/>

                        <StackPanel Orientation="Horizontal" Margin="0,5">
                             <TextBlock Text="🕯️ Files Scanned:" Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Width="100"/>
                             <TextBlock x:Name="FilesScannedText" Text="0" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,5">
                             <TextBlock Text="🛡️ Threats:" Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Width="100"/>
                             <TextBlock x:Name="ThreatsFoundText" Text="0" Foreground="{DynamicResource ErrorBrush}" FontSize="12" FontWeight="Bold"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Results View (Hidden by default) -->
                <Grid x:Name="ResultsPanel" Grid.ColumnSpan="2" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="KẾT QUẢ PHÂN TÍCH / SCAN RESULTS" Foreground="{DynamicResource CyanBrush}" FontSize="18" FontWeight="SemiBold"/>
                        <Border Background="{DynamicResource ErrorBrush}" CornerRadius="4" Margin="15,0,0,0" Padding="8,2" VerticalAlignment="Center">
                             <TextBlock x:Name="ResultThreatCount" Text="0 THREATS" Foreground="White" FontSize="10" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>
                    
                    <ListView x:Name="ThreatsList" Grid.Row="1" Background="{DynamicResource SurfaceBrush}" BorderThickness="0" Foreground="White">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource CardDarkBrush}" CornerRadius="8" Margin="0,0,0,8" Padding="12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <Border Width="40" Height="40" Background="{DynamicResource ErrorBrush}" Opacity="0.1" CornerRadius="8"/>
                                        <TextBlock Text="⚠️" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20"/>

                                        <StackPanel Grid.Column="1" Margin="15,0">
                                            <TextBlock Text="{Binding ThreatName}" FontWeight="Bold" Foreground="{DynamicResource ErrorBrush}" FontSize="14"/>
                                            <TextBlock Text="{Binding FilePath}" Foreground="{DynamicResource TextMutedBrush}" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Status}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="10" Margin="0,4,0,0"/>
                                        </StackPanel>
                                        
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                            <Button Content="CÁCH LY / QUARANTINE" Style="{DynamicResource DangerButtonStyle}" 
                                                    FontSize="11" FontWeight="Bold" Padding="15,8" Click="QuarantineItem_Click" Tag="{Binding}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    
                    <StackPanel x:Name="NoThreatsText" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed">
                        <TextBlock Text="🛡" FontSize="80" HorizontalAlignment="Center" Foreground="{DynamicResource SuccessBrush}"/>
                        <TextBlock Text="HỆ THỐNG AN TOÀN / SYSTEM SECURE" Foreground="{DynamicResource SuccessBrush}" FontSize="24" FontWeight="Bold" Margin="0,20,0,0"/>
                        <TextBlock Text="Không tìm thấy mối đe dọa nào trong lần quét này." Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    </StackPanel>
                </Grid>
                
            </Grid>

            <!-- Footer Buttons -->
            <Grid Grid.Row="3" Background="{DynamicResource SurfaceBrush}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="20,0,0,0">
                    <TextBlock Text="DATABASE v5.2.0" Foreground="{DynamicResource TextMutedBrush}" FontSize="11"/>
                    <Border Width="1" Height="12" Background="{DynamicResource BorderBrush}" Margin="15,0"/>
                    <TextBlock Text="ENGINE: ULTRA NexGen v2" Foreground="{DynamicResource CyanBrush}" FontSize="11" FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,20,0">
                    <Button x:Name="StopButton" Content="DỪNG QUÉT / STOP" Style="{DynamicResource SecondaryButtonStyle}" Margin="0,0,10,0" Click="StopButton_Click" Visibility="Collapsed" Width="150" Height="36"/>
                    <Button x:Name="StartButton" Content="BẮT ĐẦU QUÉT / START SCAN" Style="{DynamicResource PrimaryButtonStyle}" Click="StartButton_Click" Width="200" Height="36"/>
                    <Button x:Name="CloseResultButton" Content="HOÀN TẤT / COMPLETE" Style="{DynamicResource PrimaryButtonStyle}" Click="CloseButton_Click" Visibility="Collapsed" Width="150" Height="36"/>
                </StackPanel>
            </Grid>
            
        </Grid>
    </Border>
</Window>
