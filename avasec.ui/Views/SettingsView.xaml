<Window x:Class="AVASec.UI.Views.SettingsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Lang.Settings.Title}" Height="500" Width="700"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" GlassFrameThickness="0" CornerRadius="12"/>
    </WindowChrome.WindowChrome>

    <Border Background="{DynamicResource MainBackgroundGradient}" CornerRadius="12" BorderBrush="{DynamicResource BorderGlowBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Title Bar -->
                <RowDefinition Height="Auto"/>  <!-- Content Header -->
                <RowDefinition Height="*"/>     <!-- Settings Content -->
                <RowDefinition Height="Auto"/>  <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="{DynamicResource DarkSurfaceBrush}" 
                    CornerRadius="12,12,0,0" MouseLeftButtonDown="TitleBar_MouseDown" Height="40">
                <Grid Margin="15,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="⚙" FontSize="16" Margin="0,0,10,0"/>
                        <TextBlock Text="{DynamicResource Lang.Settings.Title}" Style="{DynamicResource Heading2Style}" Margin="0" FontSize="16"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="👤" x:Name="UserButton" Style="{DynamicResource IconButtonStyle}" Width="36" Height="36" Click="UserButton_Click" Foreground="White" ToolTip="Login / Đăng nhập" WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button Content="💬" x:Name="ChatToggleButton" Style="{DynamicResource IconButtonStyle}" Width="36" Height="36" Click="ChatToggle_Click" Foreground="White" Margin="0,0,5,0" ToolTip="Support Chat (Dashboard) / Hỗ trợ Chat" WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button Content="☰" Style="{DynamicResource IconButtonStyle}" Width="36" Height="36" Click="Toolbox_Click" Foreground="White" WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button Content="─" Style="{DynamicResource IconButtonStyle}" Width="36" Height="36" Click="MinimizeButton_Click" Foreground="White" ToolTip="Minimize to Taskbar / Thu nhỏ xuống thanh tác vụ" WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button Content="➘" Style="{DynamicResource IconButtonStyle}" Width="36" Height="36" Click="TrayButton_Click" Foreground="White" ToolTip="Hide / Ẩn" WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button Content="✕" Style="{DynamicResource IconButtonStyle}" Width="36" Height="36" Click="CloseButton_Click" Foreground="White" ToolTip="Close / Đóng" WindowChrome.IsHitTestVisibleInChrome="True"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content Header -->
            <Border Grid.Row="1" Background="Transparent" Padding="20">
                <TextBlock Text="⚙️ Cài đặt Hệ thống / System Settings" 
                           FontSize="20" FontWeight="Bold" 
                           Foreground="{DynamicResource TextBrush}"/>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="20">
                <StackPanel>
                    
                    <!-- General Settings -->
                    <GroupBox Header="{DynamicResource Lang.Settings.General}" Margin="0,0,0,15" Foreground="{DynamicResource TextSecondaryBrush}" BorderBrush="{StaticResource SurfaceBrush}">
                        <StackPanel Margin="10">
                            <DockPanel Margin="0,0,0,10">
                                <TextBlock Text="{DynamicResource Lang.Settings.Language}" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                                <ComboBox x:Name="LanguageComboBox" Width="150" HorizontalAlignment="Right"
                                          SelectionChanged="LanguageComboBox_SelectionChanged">
                                    <ComboBoxItem Content="Tiếng Việt" Tag="vi-VN"/>
                                    <ComboBoxItem Content="English" Tag="en-US"/>
                                    <ComboBoxItem Content="Song ngữ / Bilingual (VI-EN)" Tag="vi-EN"/>
                                </ComboBox>
                            </DockPanel>

                            <CheckBox x:Name="AutoStartCheck" Content="{DynamicResource Lang.Settings.AutoStart}" 
                                      Foreground="{DynamicResource TextBrush}" Margin="0,0,0,10"/>
                            <CheckBox x:Name="MinimizeToTrayCheck" Content="{DynamicResource Lang.Settings.MinimizeTray}" 
                                      Foreground="{DynamicResource TextBrush}" Margin="0,0,0,10"/>
                            <CheckBox x:Name="DarkModeCheck" Content="Giao diện Tối / Dark Mode" 
                                      Foreground="{DynamicResource TextBrush}" Margin="0,0,0,10"
                                      Checked="DarkModeCheck_Changed" Unchecked="DarkModeCheck_Changed"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- Protection Settings -->
                    <GroupBox Header="{DynamicResource Lang.Settings.Security}" Margin="0,0,0,15" Foreground="{DynamicResource TextSecondaryBrush}" BorderBrush="{StaticResource SurfaceBrush}">
                        <StackPanel Margin="10">
                            <CheckBox x:Name="RealTimeProtectionCheck" Content="{DynamicResource Lang.Settings.RealTime}" 
                                      Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBlock Text="{DynamicResource Lang.Settings.RealTime.Desc}" 
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="20,0,0,10"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- Advanced Tools -->
                    <GroupBox Header="{DynamicResource Lang.Settings.Advanced}" Margin="0,0,0,15" Foreground="{DynamicResource TextSecondaryBrush}" BorderBrush="{StaticResource SurfaceBrush}">
                        <StackPanel Margin="10">
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource Lang.Settings.WinUpdate}" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{DynamicResource Lang.Settings.WinUpdate.Desc}" 
                                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                                </StackPanel>
                                <ToggleButton x:Name="WindowsUpdateToggle" Content="Enabled" Grid.Column="1" Width="80" Click="WindowsUpdateToggle_Click"/>
                            </Grid>
                            
                            <Button Content="{DynamicResource Lang.Settings.PrinterFix}" 
                                    HorizontalAlignment="Left" Padding="15,8" Margin="0,5"
                                    Click="FixPrinter_Click" Background="{StaticResource SurfaceBrush}" Foreground="{DynamicResource TextBrush}" BorderThickness="0"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- Accessibility -->
                    <GroupBox Header="Trợ năng / Accessibility" Margin="0,0,0,15" Foreground="{DynamicResource TextSecondaryBrush}" BorderBrush="{StaticResource SurfaceBrush}">
                        <StackPanel Margin="10">
                            <DockPanel Margin="0,0,0,10">
                                <TextBlock Text="Cỡ chữ / Font scale" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                                <ComboBox x:Name="FontScaleComboBox" Width="150" HorizontalAlignment="Right"
                                          SelectionChanged="FontScaleComboBox_SelectionChanged">
                                    <ComboBoxItem Content="100%" Tag="1.0" IsSelected="True"/>
                                    <ComboBoxItem Content="110%" Tag="1.1"/>
                                    <ComboBoxItem Content="125%" Tag="1.25"/>
                                    <ComboBoxItem Content="150%" Tag="1.5"/>
                                </ComboBox>
                            </DockPanel>
                            <CheckBox x:Name="HighContrastCheck" Content="Tương phản cao / High contrast"
                                      Foreground="{DynamicResource TextBrush}" Margin="0,0,0,10"
                                      Checked="HighContrastCheck_Changed" Unchecked="HighContrastCheck_Changed"/>
                            <Button Content="🔄 Xem lại hướng dẫn / Replay onboarding" Padding="12,6"
                                    HorizontalAlignment="Left" Background="{StaticResource SurfaceBrush}"
                                    Foreground="{DynamicResource TextBrush}" BorderThickness="0"
                                    Click="ReplayOnboarding_Click"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- About / Giới thiệu -->
                    <GroupBox Header="Giới thiệu / About" Margin="0,0,0,15" Foreground="{DynamicResource TextSecondaryBrush}" BorderBrush="{StaticResource SurfaceBrush}">
                        <StackPanel Margin="10">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="🛡️" FontSize="20" VerticalAlignment="Center"/>
                                <StackPanel Margin="8,0,0,0">
                                    <TextBlock Text="AVA Security" FontSize="16" FontWeight="Bold" 
                                               Foreground="{DynamicResource TextBrush}"/>
                                    <TextBlock x:Name="SettingsVersionText" Text="v2.0.0" FontSize="11" 
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="Giấy phép / License: " FontSize="12" 
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock x:Name="SettingsLicenseText" Text="Free" FontSize="12" 
                                           FontWeight="SemiBold" Foreground="{DynamicResource AccentBlueBrush}"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <Button Content="ℹ️ Chi tiết / About" Padding="12,6" Margin="0,0,8,0"
                                        Background="{StaticResource SurfaceBrush}" Foreground="{DynamicResource TextBrush}" 
                                        BorderThickness="0" Click="AboutButton_Click" Cursor="Hand"/>
                                <Button Content="🚀 Nâng cấp / Upgrade" Padding="12,6" Margin="0,0,8,0"
                                        Background="{StaticResource AccentBlueBrush}" Foreground="White" 
                                        BorderThickness="0" Click="UpgradeButton_Click" Cursor="Hand"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                </StackPanel>
            </ScrollViewer>
            
            <!-- Footer -->
            <Border Grid.Row="3" Background="{StaticResource SurfaceBrush}" Padding="15" CornerRadius="0,0,12,12">
                <Grid>
                    <Button Content="Đăng nhập / Login" Width="140" HorizontalAlignment="Left"
                            Style="{StaticResource PrimaryButtonStyle}" Click="Login_Click"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="{DynamicResource Lang.Common.Cancel}" Width="100" Margin="0,0,10,0" Padding="10,5" 
                                Background="Transparent" Foreground="{DynamicResource TextBrush}" BorderBrush="{StaticResource TextSecondaryBrush}"
                                Click="Cancel_Click"/>
                        <Button Content="{DynamicResource Lang.Common.Save}" Width="100" Padding="10,5" 
                                Background="{StaticResource PrimaryBrush}" Foreground="White" BorderThickness="0"
                                Click="Save_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
