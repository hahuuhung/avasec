                                                <Border Style="{DynamicResource FeatureCardStyle}" Width="200" Margin="0,0,16,16" MouseLeftButtonUp="Undelete_Click">
                                                    <StackPanel>
                                                        <TextBlock Text="♻️" FontSize="32" Margin="0,0,0,10"/>
                                                        <TextBlock Text="{DynamicResource Lang.Recovery.Title}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                        <TextBlock Text="Recover lost files &amp; Unformat" FontSize="12" Foreground="#94A3B8" TextWrapping="Wrap" Margin="0,6,0,0"/>
