                                                <Border Style="{DynamicResource FeatureCardStyle}" Width="200" Margin="0,0,16,16" MouseLeftButtonUp="ProcessManager_Click">
                                                    <StackPanel>
                                                        <TextBlock Text="📊" FontSize="32" Margin="0,0,0,10"/>
                                                        <TextBlock Text="Process Manager" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                        <TextBlock Text="Monitor running apps" FontSize="12" Foreground="#94A3B8" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                                
                                                <!-- Auto Shutdown -->
                                                <Border Style="{DynamicResource FeatureCardStyle}" Width="200" Margin="0,0,16,16" MouseLeftButtonUp="AutoShutdown_Click">
                                                    <StackPanel>
                                                        <TextBlock Text="⏱️" FontSize="32" Margin="0,0,0,10"/>
                                                        <TextBlock Text="Auto Shutdown" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                        <TextBlock Text="Schedule power tasks" FontSize="12" Foreground="#94A3B8" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                                    </StackPanel>
                                                </Border>

                                                <!-- System Monitor -->
                                                <Border Style="{DynamicResource StatCardStyle}" Width="200" Margin="0,0,16,16" MouseLeftButtonUp="SystemMonitor_Click" Cursor="Hand">
                                                    <StackPanel>
                                                        <TextBlock Text="{DynamicResource Lang.Tools.Monitor}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                                                        <Grid Margin="0,0,0,8">
                                                            <TextBlock Text="CPU" FontSize="12" Foreground="#94A3B8"/>
                                                            <TextBlock x:Name="LegacyCpuText" Text="12%" HorizontalAlignment="Right" FontSize="12" Foreground="{DynamicResource AccentBlueBrush}"/>
                                                        </Grid>
                                                        <ProgressBar x:Name="CpuProgressBar" Value="12" Height="6" Background="{DynamicResource BorderBrush}" Foreground="{DynamicResource AccentBlueBrush}"/>
                                                        <Grid Margin="0,10,0,8">
                                                            <TextBlock Text="RAM" FontSize="12" Foreground="#94A3B8"/>
                                                            <TextBlock x:Name="LegacyRamText" Text="45%" HorizontalAlignment="Right" FontSize="12" Foreground="{DynamicResource GreenBrush}"/>
                                                        </Grid>
                                                        <ProgressBar x:Name="RamProgressBar" Value="45" Height="6" Background="{DynamicResource BorderBrush}" Foreground="{DynamicResource GreenBrush}"/>
                                                    </StackPanel>
                                                </Border>
                                            </WrapPanel>
                                        </Border>
                                    </Expander>
                                </StackPanel>
                            </StackPanel>

                            <!-- Other panels will be shown/hidden based on navigation -->
                            <StackPanel x:Name="CleanUpPanel" Visibility="Collapsed">
                                    <TextBlock Text="{DynamicResource Lang.Panel.Cleanup}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                                    <WrapPanel>
                                        <Border Style="{DynamicResource ToolCardStyle}" Width="280" Margin="0,0,16,12" MouseLeftButtonUp="DiskCleanup_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="🧹" FontSize="28" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                                <StackPanel>
                                                    <TextBlock Text="{DynamicResource Lang.Action.DiskCleanup}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource AccentBlueBrush}"/>
                                                    <TextBlock Text="{DynamicResource Lang.Action.DiskCleanup.Desc}" FontSize="12" Foreground="#94A3B8"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{DynamicResource ToolCardStyle}" Width="280" Margin="0,0,16,12" MouseLeftButtonUp="RegistryTweaks_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="📋" FontSize="28" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                                <StackPanel>
                                                    <TextBlock Text="{DynamicResource Lang.Action.Registry}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource AccentBlueBrush}"/>
                                                    <TextBlock Text="{DynamicResource Lang.Tools.Registry.Desc2}" FontSize="12" Foreground="#94A3B8"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </WrapPanel>
                                </StackPanel>

                                <StackPanel x:Name="OptimizePanel" Visibility="Collapsed">
                                    <TextBlock Text="{DynamicResource Lang.Panel.Optimize}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                                    <WrapPanel>
                                        <Border Style="{DynamicResource ToolCardStyle}" Width="280" Margin="0,0,16,12" MouseLeftButtonUp="StartupManager_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="🚀" FontSize="28" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                                <StackPanel>
                                                    <TextBlock Text="{DynamicResource Lang.Action.Startup}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource AccentBlueBrush}"/>
                                                    <TextBlock Text="Improve Windows startup speed" FontSize="12" Foreground="#94A3B8"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{DynamicResource ToolCardStyle}" Width="280" Margin="0,0,16,12" MouseLeftButtonUp="RamBooster_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="💾" FontSize="28" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                                <StackPanel>
                                                    <TextBlock Text="{DynamicResource Lang.Tools.MemoryOpt}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource AccentBlueBrush}"/>
                                                    <TextBlock Text="{DynamicResource Lang.Tools.MemoryOpt.Desc}" FontSize="12" Foreground="#94A3B8"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </WrapPanel>
                                </StackPanel>

                                <StackPanel x:Name="SystemPanel" Visibility="Collapsed">
                                    <TextBlock Text="{DynamicResource Lang.Panel.System}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>
