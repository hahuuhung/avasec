                                                       Padding="16,8" FontSize="12"/>
                                            </StackPanel>
                                        </Border>
                                    </UniformGrid>
                                    </StackPanel>

                                    <!-- Advanced Tools Expander -->
                                    <StackPanel x:Name="AdvancedToolsPanelContainer">
