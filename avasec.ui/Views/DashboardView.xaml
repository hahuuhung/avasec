                                        <Border Style="{DynamicResource ToolCardStyle}" Width="280" Margin="0,0,16,12" MouseLeftButtonUp="Windows11Tweaks_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="⚙️" FontSize="28" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                                <StackPanel>
                                                    <TextBlock Text="{DynamicResource Lang.Action.Windows}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource AccentBlueBrush}"/>
                                                    <TextBlock Text="{DynamicResource Lang.Action.Windows.Desc}" FontSize="12" Foreground="#94A3B8"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{DynamicResource ToolCardStyle}" Width="280" Margin="0,0,16,12" MouseLeftButtonUp="SystemInfo_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="ℹ️" FontSize="28" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                                <StackPanel>
                                                    <TextBlock Text="{DynamicResource Lang.Tools.SysInfo}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource AccentBlueBrush}"/>
                                                    <TextBlock Text="{DynamicResource Lang.Tools.SysInfo.Desc}" FontSize="12" Foreground="#94A3B8"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </WrapPanel>
                                </StackPanel>

                                <StackPanel x:Name="GameModePanel" Visibility="Collapsed">
                                    <TextBlock Text="{DynamicResource Lang.Panel.GameMode}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                                    <local:GameModeView />
                                </StackPanel>

                                <StackPanel x:Name="PrivacyPanel" Visibility="Collapsed">
                                    <TextBlock Text="{DynamicResource Lang.Panel.Privacy}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                                    <local:PrivacyGuardianView />
                                </StackPanel>

                                <StackPanel x:Name="BenchmarkPanel" Visibility="Collapsed">
                                    <TextBlock Text="{DynamicResource Lang.Panel.Benchmark}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                                    <local:BenchmarkView />
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- ========== FOOTER / Quick Toolbar ========== -->
            <Border Grid.Row="2" Background="{DynamicResource SelectedItemBgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button Content="🛡️" Style="{DynamicResource IconButtonStyle}" ToolTip="{DynamicResource Lang.Footer.SmartScan}" Width="44" Height="44" Click="SmartScan_Click" Foreground="{DynamicResource AccentBlueBrush}"/>
                    <Button Content="🧹" Style="{DynamicResource IconButtonStyle}" ToolTip="{DynamicResource Lang.Footer.DiskCleanup}" Width="44" Height="44" Click="ToolbarDiskCleanup_Click" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <Button Content="📋" Style="{DynamicResource IconButtonStyle}" ToolTip="{DynamicResource Lang.Footer.Registry}" Width="44" Height="44" Click="ToolbarRegistry_Click" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <Button Content="🚀" Style="{DynamicResource IconButtonStyle}" ToolTip="{DynamicResource Lang.Footer.Startup}" Width="44" Height="44" Click="ToolbarStartup_Click" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <Button Content="🔒" Style="{DynamicResource IconButtonStyle}" ToolTip="{DynamicResource Lang.Footer.Privacy}" Width="44" Height="44" Click="ToolbarPrivacy_Click" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <Button Content="📁" Style="{DynamicResource IconButtonStyle}" ToolTip="{DynamicResource Lang.Footer.Files}" Width="44" Height="44" Click="ToolbarFiles_Click" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <Button Content="⚙️" Style="{DynamicResource IconButtonStyle}" ToolTip="{DynamicResource Lang.Footer.System}" Width="44" Height="44" Click="ToolbarSystem_Click" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <Button Content="🔍" Style="{DynamicResource IconButtonStyle}" ToolTip="{DynamicResource Lang.Footer.Search}" Width="44" Height="44" Click="ToolbarSearch_Click" Foreground="{DynamicResource TextSecondaryBrush}"/>
