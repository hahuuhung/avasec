                                                </Border>
                                                
                                                <!-- Large Files -->
                                                <Border Style="{DynamicResource FeatureCardStyle}" Width="200" Margin="0,0,16,16" MouseLeftButtonUp="LargeFile_Click">
                                                    <StackPanel>
