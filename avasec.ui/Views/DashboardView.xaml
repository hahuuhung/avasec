                                                        <TextBlock Text="Update outdated drivers" FontSize="12" Foreground="#94A3B8" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Software Update -->
                                                <Border Style="{DynamicResource FeatureCardStyle}" Width="200" Margin="0,0,16,16" MouseLeftButtonUp="SoftwareUpdate_Click">
                                                    <StackPanel>
                                                        <TextBlock Text="⬆️" FontSize="32" Margin="0,0,0,10"/>
                                                        <TextBlock Text="Software Updater" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                        <TextBlock Text="Keep apps up-to-date" FontSize="12" Foreground="#94A3B8" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Smart Defrag -->
                                                <Border Style="{DynamicResource FeatureCardStyle}" Width="200" Margin="0,0,16,16" MouseLeftButtonUp="SmartDefrag_Click">
                                                    <StackPanel>
                                                        <TextBlock Text="💿" FontSize="32" Margin="0,0,0,10"/>
                                                        <TextBlock Text="Smart Defrag" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                        <TextBlock Text="Optimize hard drive" FontSize="12" Foreground="#94A3B8" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Internet Booster -->
                                                <Border Style="{DynamicResource FeatureCardStyle}" Width="200" Margin="0,0,16,16" MouseLeftButtonUp="InternetBooster_Click">
                                                    <StackPanel>
                                                        <TextBlock Text="🌐" FontSize="32" Margin="0,0,0,10"/>
                                                        <TextBlock Text="Internet Booster" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                        <TextBlock Text="Speed up connection" FontSize="12" Foreground="#94A3B8" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Disk Doctor -->
                                                <Border Style="{DynamicResource FeatureCardStyle}" Width="200" Margin="0,0,16,16" MouseLeftButtonUp="DiskDoctor_Click">
                                                    <StackPanel>
                                                        <TextBlock Text="🩺" FontSize="32" Margin="0,0,0,10"/>
                                                        <TextBlock Text="Disk Doctor" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                        <TextBlock Text="Fix disk errors" FontSize="12" Foreground="#94A3B8" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                                    </StackPanel>
                                                </Border>

                                                <!-- File Shredder -->
                                                <Border Style="{DynamicResource FeatureCardStyle}" Width="200" Margin="0,0,16,16" MouseLeftButtonUp="FileShredder_Click">
                                                    <StackPanel>
                                                        <TextBlock Text="📄" FontSize="32" Margin="0,0,0,10"/>
                                                        <TextBlock Text="File Shredder" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                        <TextBlock Text="Securely delete files" FontSize="12" Foreground="#94A3B8" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                                    </StackPanel>
