                                                        <TextBlock Text="Find space hogs" FontSize="12" Foreground="#94A3B8" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Empty Folder -->
                                                <Border Style="{DynamicResource FeatureCardStyle}" Width="200" Margin="0,0,16,16" MouseLeftButtonUp="EmptyFolder_Click">
                                                    <StackPanel>
                                                        <TextBlock Text="📂" FontSize="32" Margin="0,0,0,10"/>
                                                        <TextBlock Text="Empty Folder Scanner" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                        <TextBlock Text="Remove empty directories" FontSize="12" Foreground="#94A3B8" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                                
                                                <!-- Shortcut Fixer -->
                                                <Border Style="{DynamicResource FeatureCardStyle}" Width="200" Margin="0,0,16,16" MouseLeftButtonUp="ShortcutFixer_Click">
