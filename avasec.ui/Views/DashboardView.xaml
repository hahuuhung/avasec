                                                        <TextBlock Text="Remove malware &amp; threats" FontSize="12" Foreground="#94A3B8" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                                
                                                <!-- RAM Booster -->
                                                <Border Style="{DynamicResource FeatureCardStyle}" Width="200" Margin="0,0,16,16" MouseLeftButtonUp="RamBooster_Click">
                                                    <StackPanel>
                                                        <TextBlock Text="⚡" FontSize="32" Margin="0,0,0,10"/>
                                                        <TextBlock Text="Smart RAM" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                        <TextBlock Text="Optimize memory usage" FontSize="12" Foreground="#94A3B8" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Uninstaller -->
                                                <Border Style="{DynamicResource FeatureCardStyle}" Width="200" Margin="0,0,16,16" MouseLeftButtonUp="Uninstaller_Click">
                                                    <StackPanel>
                                                        <TextBlock Text="🗑️" FontSize="32" Margin="0,0,0,10"/>
                                                        <TextBlock Text="Uninstaller" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                        <TextBlock Text="Remove unwanted apps" FontSize="12" Foreground="#94A3B8" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Driver Update -->
                                                <Border Style="{DynamicResource FeatureCardStyle}" Width="200" Margin="0,0,16,16" MouseLeftButtonUp="DriverUpdate_Click">
