                                                <!-- System Booster -->
                                                <Border Style="{DynamicResource FeatureCardStyle}" Width="200" Margin="0,0,16,16" MouseLeftButtonUp="SystemBooster_Click">
                                                    <StackPanel>
                                                        <TextBlock Text="🚀" FontSize="32" Margin="0,0,0,10"/>
                                                        <TextBlock Text="{DynamicResource Lang.Tools.SystemBooster}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                        <TextBlock Text="{DynamicResource Lang.Tools.SystemBooster.Desc}" FontSize="12" Foreground="#94A3B8" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                                <!-- Virus Scanner -->
                                                <Border Style="{DynamicResource FeatureCardStyle}" Width="200" Margin="0,0,16,16" MouseLeftButtonUp="VirusScanner_Click">
                                                    <StackPanel>
                                                        <TextBlock Text="🛡️" FontSize="32" Margin="0,0,0,10"/>
