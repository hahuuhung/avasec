<Window x:Class="AVASec.UI.Views.StartupManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Startup Manager - AVA Security" 
        Height="650" Width="950"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" GlassFrameThickness="0" CornerRadius="12"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Specialized styles for this window -->
        
        <!-- Sleep Button Style -->
        <Style x:Key="SleepButton" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentTealBrush}"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="32"/>
        </Style>
        
        <!-- Ignore Link Style -->
        <Style x:Key="IgnoreLink" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock Text="{TemplateBinding Content}" 
                                   Foreground="{TemplateBinding Foreground}"
                                   TextDecorations="Underline"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource AccentTealBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Rescan Button Style -->
        <Style x:Key="RescanButton" TargetType="Button" BasedOn="{StaticResource HeaderButtonStyle}">
            <Setter Property="Content" Value="🔄 Rescan"/>
        </Style>
        
    </Window.Resources>

    <Border Background="{StaticResource MainBackgroundGradient}" CornerRadius="12" BorderBrush="{StaticResource BorderGlowBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Title Bar -->
                <RowDefinition Height="Auto"/>  <!-- Header -->
                <RowDefinition Height="Auto"/>  <!-- Column Headers -->
                <RowDefinition Height="*"/>     <!-- Items List -->
                <RowDefinition Height="Auto"/>  <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="{StaticResource DarkSurfaceBrush}" 
                    CornerRadius="12,12,0,0" MouseLeftButtonDown="TitleBar_MouseDown" Height="45">
                <Grid Margin="15,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <Button Click="Back_Click" Style="{StaticResource IconButtonStyle}" ToolTip="Back">
                        <TextBlock Text="←" FontSize="18" Margin="0,-2,0,0"/>
                    </Button>
                    
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="🚀" FontSize="18" Margin="0,0,10,0"/>
                        <TextBlock Text="Startup Manager" Style="{StaticResource Heading2Style}" Margin="0"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource IconButtonStyle}" Click="Rescan_Click" ToolTip="Rescan" Margin="0,0,10,0" WindowChrome.IsHitTestVisibleInChrome="True">
                            <TextBlock Text="🔄" FontSize="16"/>
                        </Button>
                        <Button Content="👤" x:Name="UserButton" Style="{StaticResource IconButtonStyle}" Width="36" Height="36" Click="UserButton_Click" Foreground="White" ToolTip="Login / Đăng nhập" WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button Content="💬" x:Name="ChatToggleButton" Style="{StaticResource IconButtonStyle}" Width="36" Height="36" Click="ChatToggle_Click" Foreground="White" Margin="0,0,5,0" ToolTip="Support Chat (Dashboard) / Hỗ trợ Chat" WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button Content="⚙" Style="{StaticResource IconButtonStyle}" Width="36" Height="36" Click="Settings_Click" Foreground="White" WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button Content="☰" Style="{StaticResource IconButtonStyle}" Width="36" Height="36" Click="Toolbox_Click" Foreground="White" WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button Content="─" Style="{StaticResource IconButtonStyle}" Width="36" Height="36" Click="MinimizeButton_Click" Foreground="White" ToolTip="Minimize to Taskbar / Thu nhỏ xuống thanh tác vụ" WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button Content="➘" Style="{StaticResource IconButtonStyle}" Width="36" Height="36" Click="TrayButton_Click" Foreground="White" ToolTip="Hide / Ẩn" WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button Content="✕" Style="{StaticResource IconButtonStyle}" Width="36" Height="36" Click="CloseButton_Click" Foreground="White" ToolTip="Close / Đóng" WindowChrome.IsHitTestVisibleInChrome="True"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Info Header -->
            <Border Grid.Row="1" Padding="30,25">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel>
                        <TextBlock x:Name="ProgramCountText" 
                                   Text="Đang quét hệ thống... / Scanning system..." 
                                   Style="{StaticResource Heading2Style}" 
                                   FontSize="20"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="Tắt các chương trình khởi động không cần thiết để tăng tốc độ boot Windows đến 50%.&#x0a;Disable unnecessary startup programs to boost Windows boot speed by up to 50%." 
                                   Style="{StaticResource CaptionStyle}"/>
                    </StackPanel>
                    
                    <Border Grid.Column="1" Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="15,10">
                         <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💡 Tip:" FontWeight="Bold" Foreground="{StaticResource AccentYellowBrush}" Margin="0,0,5,0"/>
                            <TextBlock Text="Các ứng dụng hệ thống quan trọng đã được ẩn an toàn.&#x0a;Critical system apps are safely hidden." Foreground="{StaticResource TextSecondaryBrush}"/>
                         </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Column Headers -->
            <Border Grid.Row="2" Background="{StaticResource DarkSurfaceBrush}" Padding="25,12" Margin="20,0,20,0" CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="200"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Text="TÊN CHƯƠNG TRÌNH / NAME" Style="{StaticResource LabelStyle}" Margin="0"/>
                    <TextBlock Grid.Column="1" Text="SỬ DỤNG / USAGE" Style="{StaticResource LabelStyle}" Margin="0"/>
                    <TextBlock Grid.Column="2" Text="MỨC ẢNH HƯỞNG / IMPACT" Style="{StaticResource LabelStyle}" Margin="20,0,0,0"/>
                    <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right" Cursor="Hand" MouseLeftButtonDown="PutAllToSleep_Click">
                        <TextBlock Text="💤" Margin="0,0,5,0"/>
                        <TextBlock Text="NGỦ TẤT CẢ / SLEEP ALL" Foreground="{StaticResource AccentTealBrush}" FontWeight="Bold" FontSize="11"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Items List -->
            <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Margin="0,10,0,20">
                <StackPanel x:Name="ItemsPanel" Margin="20,0">
                    <!-- Items will be populated dynamically -->
                </StackPanel>
            </ScrollViewer>


            <!-- Footer -->
            <Border Grid.Row="4" Background="{StaticResource DarkSurfaceBrush}" 
                    Padding="20,15" CornerRadius="0,0,12,12" BorderBrush="{StaticResource DarkBorderBrush}" BorderThickness="0,1,0,0">
                <StackPanel HorizontalAlignment="Right">
                    <Button Content="Đóng / Close" Click="CloseButton_Click" Style="{StaticResource SecondaryButtonStyle}" Padding="20,8" Height="34" FontSize="13"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
