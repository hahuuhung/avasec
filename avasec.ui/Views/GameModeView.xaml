<UserControl x:Class="AVASec.UI.Views.GameModeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="900"
             Background="#0F172A">

    <UserControl.Resources>
        <Style x:Key="ProfileRadioButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="RootBorder" 
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="2"
                                CornerRadius="12">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{DynamicResource AccentBlueBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#1E293B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,25">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🎮 Game Mode Ultra" FontSize="28" FontWeight="Bold" Foreground="White"/>
                <Border x:Name="StatusBadge" Background="#EF4444" CornerRadius="4" Padding="10,4" Margin="15,0,0,0" VerticalAlignment="Center">
                    <TextBlock x:Name="StatusBadgeText" Text="OFF" FontSize="12" Foreground="White" FontWeight="Bold"/>
                </Border>
            </StackPanel>
            <TextBlock Text="Maximize gaming performance with one click / Tối đa hóa hiệu năng gaming" 
                       FontSize="14" Foreground="#94A3B8" Margin="0,8,0,0"/>
        </StackPanel>

        <!-- Main Control Panel -->
        <Border Grid.Row="1" CornerRadius="20" Margin="0,0,0,25">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1E1E2E" Offset="0"/>
                    <GradientStop Color="#0F0F1A" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="40,35">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <!-- Left - Giant Toggle Button -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <!-- Power Button -->
                    <Button x:Name="PowerButton" Width="150" Height="150" Click="PowerButton_Click" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Grid>
                                    <!-- Outer Glow -->
                                    <Ellipse x:Name="GlowRing" Width="160" Height="160" Fill="Transparent">
                                        <Ellipse.Effect>
                                            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.5" Color="#EF4444"/>
                                        </Ellipse.Effect>
                                    </Ellipse>
                                    <!-- Button Base -->
                                    <Ellipse x:Name="ButtonBase" Width="150" Height="150" Stroke="#334155" StrokeThickness="4">
                                        <Ellipse.Fill>
                                            <RadialGradientBrush>
                                                <GradientStop Color="#1E293B" Offset="0"/>
                                                <GradientStop Color="#0F172A" Offset="1"/>
                                            </RadialGradientBrush>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                    <!-- Power Icon -->
                                    <TextBlock x:Name="PowerIcon" Text="⚡" FontSize="60" Foreground="#64748B" 
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ButtonBase" Property="Stroke" Value="#6366F1"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <TextBlock x:Name="PowerButtonLabel" Text="CLICK TO ENABLE" FontSize="14" FontWeight="SemiBold"
                               Foreground="#64748B" HorizontalAlignment="Center" Margin="0,20,0,0"/>
                </StackPanel>

                <!-- Right - Status & Stats -->
                <StackPanel Grid.Column="1" Margin="40,0,0,0" VerticalAlignment="Center">
                    <TextBlock x:Name="ActiveProfileText" Text="Profile: Not Active" FontSize="18" 
                               Foreground="White" FontWeight="SemiBold"/>
                    <TextBlock x:Name="StatusText" Text="Game Mode is currently disabled" 
                               FontSize="13" Foreground="#94A3B8" Margin="0,8,0,25"/>

                    <!-- Stats Grid -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Stat: Games Detected -->
                        <Border Grid.Row="0" Grid.Column="0" Background="#334155" CornerRadius="10" 
                                Padding="15,12" Margin="0,0,8,8">
                            <StackPanel>
                                <TextBlock Text="🎯 Games Detected" FontSize="11" Foreground="#94A3B8"/>
                                <TextBlock x:Name="GamesDetectedText" Text="0" FontSize="24" 
                                           Foreground="White" FontWeight="Bold" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Stat: Optimized Processes -->
                        <Border Grid.Row="0" Grid.Column="1" Background="#334155" CornerRadius="10" 
                                Padding="15,12" Margin="8,0,0,8">
                            <StackPanel>
                                <TextBlock Text="⚡ Optimized" FontSize="11" Foreground="#94A3B8"/>
                                <TextBlock x:Name="OptimizedText" Text="0" FontSize="24" 
                                           Foreground="White" FontWeight="Bold" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Stat: Memory Freed -->
                        <Border Grid.Row="1" Grid.Column="0" Background="#334155" CornerRadius="10" 
                                Padding="15,12" Margin="0,8,8,0">
                            <StackPanel>
                                <TextBlock Text="💾 Memory Freed" FontSize="11" Foreground="#94A3B8"/>
                                <TextBlock x:Name="MemoryFreedText" Text="0 MB" FontSize="24" 
                                           Foreground="White" FontWeight="Bold" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Stat: Power Plan -->
                        <Border Grid.Row="1" Grid.Column="1" Background="#334155" CornerRadius="10" 
                                Padding="15,12" Margin="8,8,0,0">
                            <StackPanel>
                                <TextBlock Text="🔋 Power Plan" FontSize="11" Foreground="#94A3B8"/>
                                <TextBlock x:Name="PowerPlanText" Text="Balanced" FontSize="18" 
                                           Foreground="White" FontWeight="Bold" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Profile Selection & Settings -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left - Profile Selection -->
            <Border Grid.Column="0" Background="#1E293B" CornerRadius="16" Padding="25" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="📋 Select Profile" FontSize="18" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock Text="Choose optimization level" FontSize="12" Foreground="#94A3B8" Margin="0,5,0,20"/>

                    <!-- Profile Cards -->
                    <RadioButton x:Name="ProfileBalanced" GroupName="Profile" IsChecked="True" 
                                 Style="{StaticResource ProfileRadioButtonStyle}" Margin="0,0,0,10">
                        <Border Background="#0F172A" CornerRadius="10" Padding="15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="⚖️" FontSize="24" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                    <TextBlock Text="Balanced" FontWeight="SemiBold" Foreground="White"/>
                                    <TextBlock Text="Light optimization, keeps apps running" FontSize="11" Foreground="#94A3B8"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </RadioButton>

                    <RadioButton x:Name="ProfilePerformance" GroupName="Profile" 
                                 Style="{StaticResource ProfileRadioButtonStyle}" Margin="0,0,0,10">
                        <Border Background="#0F172A" CornerRadius="10" Padding="15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="🚀" FontSize="24" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                    <TextBlock Text="Performance" FontWeight="SemiBold" Foreground="White"/>
                                    <TextBlock Text="Strong optimization, closes background apps" FontSize="11" Foreground="#94A3B8"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </RadioButton>

                    <RadioButton x:Name="ProfileUltra" GroupName="Profile" 
                                 Style="{StaticResource ProfileRadioButtonStyle}" Margin="0,0,0,10">
                        <Border Background="#0F172A" CornerRadius="10" Padding="15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="⚡" FontSize="24" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                    <TextBlock Text="Ultra" FontWeight="SemiBold" Foreground="White"/>
                                    <TextBlock Text="Maximum performance, closes all non-essential" FontSize="11" Foreground="#94A3B8"/>
                                </StackPanel>
                                <Border Grid.Column="2" Background="#F59E0B" CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                                    <TextBlock Text="RECOMMENDED" FontSize="9" Foreground="White" FontWeight="Bold"/>
                                </Border>
                            </Grid>
                        </Border>
                    </RadioButton>

                    <RadioButton x:Name="ProfileStream" GroupName="Profile" 
                                 Style="{StaticResource ProfileRadioButtonStyle}">
                        <Border Background="#0F172A" CornerRadius="10" Padding="15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="📺" FontSize="24" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                    <TextBlock Text="Stream" FontWeight="SemiBold" Foreground="White"/>
                                    <TextBlock Text="For streamers - keeps OBS, Discord active" FontSize="11" Foreground="#94A3B8"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </RadioButton>
                </StackPanel>
            </Border>

            <!-- Right - Detected Games & Quick Actions -->
            <Border Grid.Column="1" Background="#1E293B" CornerRadius="16" Padding="25" Margin="12,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="🎮 Detected Games" FontSize="18" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock Text="Games currently running on your system" FontSize="12" Foreground="#94A3B8" Margin="0,5,0,15"/>
                    </StackPanel>

                    <!-- Games List -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="GamesList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#0F172A" CornerRadius="8" Padding="12,10" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="🎯" FontSize="16" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding}" FontSize="13" 
                                                       Foreground="White" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                            <Border Grid.Column="2" Background="#10B981" CornerRadius="4" Padding="8,3">
                                                <TextBlock Text="RUNNING" FontSize="9" Foreground="White" FontWeight="Bold"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Empty State -->
                    <TextBlock x:Name="NoGamesText" Grid.Row="1" Text="No games detected. Start a game to see it here." 
                               FontSize="13" Foreground="#64748B" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                    <!-- Quick Actions -->
                    <StackPanel Grid.Row="2" Margin="0,15,0,0">
                        <Button x:Name="RefreshBtn" Content="🔄 Refresh Games" 
                                Style="{StaticResource SecondaryButtonStyle}" 
                                Padding="15,10" HorizontalAlignment="Stretch"
                                Click="RefreshGames_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
