<Window x:Class="AVASec.UI.Views.SplashScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AVA Security"
        Height="400" Width="600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True">

    <Border CornerRadius="16" BorderThickness="0">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0F172A" Offset="0"/>
                <GradientStop Color="#1E293B" Offset="0.5"/>
                <GradientStop Color="#0F172A" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="40" Opacity="0.5" ShadowDepth="0"/>
        </Border.Effect>

        <Grid>
            <!-- Background glow effect / Hiệu ứng phát sáng nền -->
            <Ellipse Width="300" Height="300" Opacity="0.08" 
                     HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-60,0,0">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#06B6D4" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <!-- Logo & App Name / Logo và Tên ứng dụng -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="🦉" FontSize="48" VerticalAlignment="Center"/>
                    <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                        <TextBlock FontSize="36" FontWeight="Bold" Foreground="White">
                            <Run Text="AVA Security"/>
                            <Run Text=" Pro" FontSize="20" Foreground="#06B6D4"/>
                        </TextBlock>
                        <TextBlock Text="Faster. Safer. Smarter. / Máy nhanh hơn. An toàn hơn."
                                   FontSize="13" Foreground="#64748B" Margin="0,-2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Version / Phiên bản -->
                <TextBlock x:Name="VersionText" Text="v2.0.0" 
                           FontSize="12" Foreground="#475569" 
                           HorizontalAlignment="Center" Margin="0,12,0,0"/>

                <!-- Loading bar / Thanh tải -->
                <Border CornerRadius="4" Background="#1E293B" Width="300" Height="6" 
                        Margin="0,28,0,0" BorderBrush="#334155" BorderThickness="1">
                    <Border x:Name="ProgressBar" CornerRadius="3" 
                            HorizontalAlignment="Left" Width="0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#06B6D4" Offset="0"/>
                                <GradientStop Color="#2196F3" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </Border>

                <!-- Status text / Trạng thái -->
                <TextBlock x:Name="StatusText" Text="Đang khởi tạo... / Initializing..."
                           FontSize="11" Foreground="#64748B" 
                           HorizontalAlignment="Center" Margin="0,12,0,0"/>
            </StackPanel>

            <!-- Copyright / Bản quyền -->
            <TextBlock Text="© 2026 AVA Security Team. All rights reserved."
                       FontSize="10" Foreground="#334155"
                       HorizontalAlignment="Center" VerticalAlignment="Bottom" 
                       Margin="0,0,0,16"/>
        </Grid>
    </Border>
</Window>
