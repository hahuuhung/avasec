<UserControl x:Class="AVASec.UI.Views.BenchmarkView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             Background="#0F172A">

    <UserControl.Resources>
        <!-- Progress Ring Style -->
        <Style x:Key="ScoreRingStyle" TargetType="Ellipse">
            <Setter Property="Stroke" Value="#334155"/>
            <Setter Property="StrokeThickness" Value="8"/>
            <Setter Property="Fill" Value="Transparent"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,30">
            <TextBlock Text="⚡ Performance Benchmark" 
                       FontSize="28" FontWeight="Bold" Foreground="White"/>
            <TextBlock Text="Test your system performance and compare results / Kiểm tra hiệu năng hệ thống" 
                       FontSize="14" Foreground="#94A3B8" Margin="0,8,0,0"/>
        </StackPanel>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel - Overall Score -->
            <Border Grid.Column="0" Background="#1E293B" CornerRadius="16" Padding="30" Margin="0,0,15,0">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <!-- Score Circle -->
                    <Grid Width="180" Height="180" x:Name="ScoreCircle">
                        <!-- Background Circle -->
                        <Ellipse Width="180" Height="180" Stroke="#334155" StrokeThickness="10" Fill="Transparent"/>
                        <!-- Progress Circle (animated) -->
                        <Ellipse x:Name="ProgressRing" Width="180" Height="180" 
                                 Stroke="#6366F1" StrokeThickness="10" Fill="Transparent"
                                 StrokeDashArray="0 100" StrokeDashCap="Round"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <RotateTransform Angle="-90"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>
                        <!-- Score Text -->
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock x:Name="ScoreText" Text="--" FontSize="48" FontWeight="Bold" 
                                       Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="GradeText" Text="Not Tested" FontSize="14" 
                                       Foreground="#94A3B8" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="OVERALL SCORE" FontSize="12" Foreground="#64748B" 
                               HorizontalAlignment="Center" Margin="0,20,0,0"/>

                    <!-- Status Text -->
                    <TextBlock x:Name="StatusText" Text="Ready to benchmark" 
                               FontSize="12" Foreground="#94A3B8" 
                               HorizontalAlignment="Center" Margin="0,15,0,0"/>

                    <!-- Progress Bar -->
                    <Border Background="#334155" CornerRadius="4" Height="8" Margin="0,15,0,0" Width="150">
                        <Border x:Name="ProgressBar" Background="#6366F1" CornerRadius="4" 
                                HorizontalAlignment="Left" Width="0"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Right Panel - Component Scores -->
            <Grid Grid.Column="1" Margin="15,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- CPU Card -->
                <Border Grid.Row="0" Style="{StaticResource MetricCardStyle}" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#6366F1" CornerRadius="12" Width="50" Height="50" 
                                VerticalAlignment="Center">
                            <TextBlock Text="🖥️" FontSize="24" HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="CPU Performance" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock x:Name="CPUName" Text="Intel Core / AMD Ryzen" 
                                       FontSize="12" Foreground="#94A3B8" Margin="0,4,0,0"/>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <TextBlock Text="Single: " FontSize="11" Foreground="#64748B"/>
                                <TextBlock x:Name="CPUSingleScore" Text="--" FontSize="11" Foreground="#6366F1"/>
                                <TextBlock Text="  |  Multi: " FontSize="11" Foreground="#64748B"/>
                                <TextBlock x:Name="CPUMultiScore" Text="--" FontSize="11" Foreground="#6366F1"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <TextBlock x:Name="CPUScore" Text="--" FontSize="32" FontWeight="Bold" 
                                       Foreground="#6366F1" HorizontalAlignment="Right"/>
                            <TextBlock Text="pts" FontSize="12" Foreground="#64748B" 
                                       HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Memory Card -->
                <Border Grid.Row="1" Style="{StaticResource MetricCardStyle}" Margin="0,5,0,5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#10B981" CornerRadius="12" Width="50" Height="50" 
                                VerticalAlignment="Center">
                            <TextBlock Text="💾" FontSize="24" HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Memory Performance" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock x:Name="MemoryInfo" Text="-- GB Total" 
                                       FontSize="12" Foreground="#94A3B8" Margin="0,4,0,0"/>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <TextBlock Text="Read: " FontSize="11" Foreground="#64748B"/>
                                <TextBlock x:Name="MemReadSpeed" Text="-- MB/s" FontSize="11" Foreground="#10B981"/>
                                <TextBlock Text="  |  Write: " FontSize="11" Foreground="#64748B"/>
                                <TextBlock x:Name="MemWriteSpeed" Text="-- MB/s" FontSize="11" Foreground="#10B981"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <TextBlock x:Name="MemoryScore" Text="--" FontSize="32" FontWeight="Bold" 
                                       Foreground="#10B981" HorizontalAlignment="Right"/>
                            <TextBlock Text="pts" FontSize="12" Foreground="#64748B" 
                                       HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Disk Card -->
                <Border Grid.Row="2" Style="{StaticResource MetricCardStyle}" Margin="0,10,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#F59E0B" CornerRadius="12" Width="50" Height="50" 
                                VerticalAlignment="Center">
                            <TextBlock Text="💿" FontSize="24" HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Disk Performance" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock x:Name="DiskInfo" Text="-- GB Free / -- GB Total" 
                                       FontSize="12" Foreground="#94A3B8" Margin="0,4,0,0"/>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <TextBlock Text="Seq R: " FontSize="11" Foreground="#64748B"/>
                                <TextBlock x:Name="DiskSeqRead" Text="-- MB/s" FontSize="11" Foreground="#F59E0B"/>
                                <TextBlock Text="  |  Seq W: " FontSize="11" Foreground="#64748B"/>
                                <TextBlock x:Name="DiskSeqWrite" Text="-- MB/s" FontSize="11" Foreground="#F59E0B"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <TextBlock x:Name="DiskScore" Text="--" FontSize="32" FontWeight="Bold" 
                                       Foreground="#F59E0B" HorizontalAlignment="Right"/>
                            <TextBlock Text="pts" FontSize="12" Foreground="#64748B" 
                                       HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Footer - Action Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,30,0,0">
            <Button x:Name="StartBenchmarkBtn" Content="▶ Start Benchmark" 
                    Style="{StaticResource PrimaryButtonStyle}"
                    Padding="30,12" FontSize="14" Margin="0,0,10,0"
                    Click="StartBenchmark_Click"/>
            <Button x:Name="CompareBtn" Content="📊 Compare Results" 
                    Style="{StaticResource SecondaryButtonStyle}"
                    Padding="20,12" FontSize="14" Margin="10,0,0,0"
                    Click="CompareResults_Click" IsEnabled="False"/>
        </StackPanel>
    </Grid>
</UserControl>
