<Window x:Class="AVASec.UI.Views.UpgradeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nâng cấp AVA Security / Upgrade AVA Security"
        Height="680" Width="900"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Border Background="{StaticResource ContentBgBrush}" CornerRadius="16" 
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="30" Opacity="0.3" ShadowDepth="0"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar / Thanh tiêu đề -->
            <Border Grid.Row="0" Background="{StaticResource AccentBlueBrush}" CornerRadius="16,16,0,0" Padding="24,16">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="🚀 Nâng cấp AVA Security / Upgrade to Ultra" 
                                   FontSize="22" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Mở khoá tất cả tính năng chuyên nghiệp / Unlock all professional features" 
                                   FontSize="13" Foreground="#CCFFFFFF" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top"
                            Background="Transparent" Foreground="White" BorderThickness="0"
                            FontSize="18" Cursor="Hand" Click="CloseButton_Click"
                            Width="32" Height="32"/>
                </Grid>
            </Border>

            <!-- Current Status / Trạng thái hiện tại -->
            <Border Grid.Row="1" Background="{StaticResource CardBgBrush}" Margin="24,16,24,0" 
                    CornerRadius="12" Padding="20,14">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📋" FontSize="20" VerticalAlignment="Center"/>
                    <StackPanel Margin="12,0,0,0">
                        <TextBlock x:Name="CurrentTierText" Text="Gói hiện tại: Free / Current Plan: Free" 
                                   FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock x:Name="RemainingDaysText" Text="" 
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Pricing Cards / Thẻ bảng giá -->
            <Grid Grid.Row="2" Margin="24,16,24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Free Plan -->
                <Border Grid.Column="0" Background="{StaticResource CardBgBrush}" CornerRadius="12" 
                        Margin="0,0,8,0" Padding="20" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="FREE" FontSize="12" FontWeight="Bold" 
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Text="Cơ bản / Basic" FontSize="16" FontWeight="SemiBold" Margin="0,4,0,0"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <TextBlock Text="$0" FontSize="36" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="/mãi mãi" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" 
                                       VerticalAlignment="Bottom" Margin="4,0,0,8"/>
                        </StackPanel>
                        <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,12"/>
                        <StackPanel>
                            <TextBlock Text="✅ Giám sát hệ thống / System Monitor" FontSize="12" Margin="0,6" 
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="✅ Dọn dẹp cơ bản / Basic Cleanup" FontSize="12" Margin="0,6" 
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="✅ Quét virus nhanh / Quick Scan" FontSize="12" Margin="0,6" 
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="❌ Game Booster" FontSize="12" Margin="0,6" 
                                       Foreground="{StaticResource TextMutedBrush}"/>
                            <TextBlock Text="❌ Registry Tweaks" FontSize="12" Margin="0,6" 
                                       Foreground="{StaticResource TextMutedBrush}"/>
                            <TextBlock Text="❌ Privacy Guardian" FontSize="12" Margin="0,6" 
                                       Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Ultra Plan (Recommended) -->
                <Border Grid.Column="1" CornerRadius="12" Margin="8,0" Padding="2"
                        BorderThickness="0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#2196F3" Offset="0"/>
                            <GradientStop Color="#1976D2" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border Background="{StaticResource CardBgBrush}" CornerRadius="10" Padding="20">
                        <StackPanel>
                            <Grid>
                                <TextBlock Text="ULTRA" FontSize="12" FontWeight="Bold" 
                                           Foreground="{StaticResource AccentBlueBrush}" />
                                <Border HorizontalAlignment="Right" Background="{StaticResource AccentBlueBrush}" 
                                        CornerRadius="4" Padding="8,3">
                                    <TextBlock Text="⭐ Khuyên dùng" FontSize="10" Foreground="White" FontWeight="Bold"/>
                                </Border>
                            </Grid>
                            <TextBlock Text="Chuyên nghiệp / Pro" FontSize="16" FontWeight="SemiBold" Margin="0,4,0,0"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <TextBlock Text="$19" FontSize="36" FontWeight="Bold" Foreground="{StaticResource AccentBlueBrush}"/>
                                <TextBlock Text="/năm" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" 
                                           VerticalAlignment="Bottom" Margin="4,0,0,8"/>
                            </StackPanel>
                            <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,12"/>
                            <StackPanel>
                                <TextBlock Text="✅ Tất cả tính năng Free" FontSize="12" Margin="0,6" 
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="✅ Game Booster Ultra" FontSize="12" Margin="0,6" FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentBlueBrush}"/>
                                <TextBlock Text="✅ Registry Tweaks" FontSize="12" Margin="0,6" FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentBlueBrush}"/>
                                <TextBlock Text="✅ Privacy Guardian" FontSize="12" Margin="0,6" FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentBlueBrush}"/>
                                <TextBlock Text="✅ System Booster" FontSize="12" Margin="0,6" FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentBlueBrush}"/>
                                <TextBlock Text="✅ Benchmark + 10 Tools" FontSize="12" Margin="0,6" FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentBlueBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>

                <!-- Lifetime Plan -->
                <Border Grid.Column="2" Background="{StaticResource CardBgBrush}" CornerRadius="12" 
                        Margin="8,0,0,0" Padding="20" BorderBrush="{StaticResource WarningBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="LIFETIME" FontSize="12" FontWeight="Bold" 
                                   Foreground="{StaticResource WarningBrush}" />
                        <TextBlock Text="Trọn đời / Forever" FontSize="16" FontWeight="SemiBold" Margin="0,4,0,0"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <TextBlock Text="$99" FontSize="36" FontWeight="Bold" Foreground="{StaticResource WarningBrush}"/>
                            <TextBlock Text="/1 lần" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" 
                                       VerticalAlignment="Bottom" Margin="4,0,0,8"/>
                        </StackPanel>
                        <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,12"/>
                        <StackPanel>
                            <TextBlock Text="✅ Tất cả tính năng Ultra" FontSize="12" Margin="0,6" 
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="✅ Cập nhật trọn đời" FontSize="12" Margin="0,6" FontWeight="SemiBold"
                                       Foreground="{StaticResource WarningBrush}"/>
                            <TextBlock Text="✅ Hỗ trợ ưu tiên / Priority" FontSize="12" Margin="0,6" FontWeight="SemiBold"
                                       Foreground="{StaticResource WarningBrush}"/>
                            <TextBlock Text="✅ Không giới hạn thiết bị" FontSize="12" Margin="0,6" FontWeight="SemiBold"
                                       Foreground="{StaticResource WarningBrush}"/>
                            <TextBlock Text="🏆 Best Value" FontSize="12" Margin="0,6" FontWeight="Bold"
                                       Foreground="{StaticResource WarningBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- License Key Input & Actions / Nhập mã kích hoạt -->
            <Border Grid.Row="3" Margin="24,16,24,24" Background="{StaticResource CardBgBrush}" 
                    CornerRadius="12" Padding="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="LicenseKeyInput" Grid.Column="0"
                             FontSize="14" Padding="12,10"
                             Background="{StaticResource LightBgBrush}"
                             BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             Text="" VerticalContentAlignment="Center">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Tag" Value="Nhập mã kích hoạt / Enter license key (SA-XXXX-XXXX-XXXX-XXXX)"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <Button x:Name="ActivateButton" Grid.Column="1" Content="🔑 Kích hoạt / Activate" 
                            Margin="12,0,0,0" Padding="20,10" FontSize="14" FontWeight="SemiBold"
                            Background="{StaticResource AccentBlueBrush}" Foreground="White"
                            BorderThickness="0" Cursor="Hand" Click="ActivateButton_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button x:Name="BuyOnlineButton" Grid.Column="2" Content="🛒 Mua Online / Buy" 
                            Margin="8,0,0,0" Padding="20,10" FontSize="14" FontWeight="SemiBold"
                            Background="{StaticResource SuccessBrush}" Foreground="White"
                            BorderThickness="0" Cursor="Hand" Click="BuyOnlineButton_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
