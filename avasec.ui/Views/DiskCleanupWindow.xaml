<Window x:Class="AVASec.UI.Views.DiskCleanupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AVASec.UI.Views"
        mc:Ignorable="d"
        Title="{DynamicResource Lang.Tools.DiskCleanup}" Height="720" Width="1050"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="Segoe UI Variable Display, Segoe UI, Arial">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Colors.xaml"/>
                <ResourceDictionary Source="/Resources/ButtonStyles.xaml"/>
                <ResourceDictionary Source="/Resources/Animations.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Icons -->
            <Geometry x:Key="Icon.Broom">M19.36,2.72L20.78,4.14L5.41,19.51C4.63,20.29 3.37,20.29 2.59,19.51C1.81,18.73 1.81,17.47 2.59,16.69L19.36,2.72M20.71,7.07L22.12,8.49L17.88,12.73L16.46,11.31L20.71,7.07Z</Geometry>
            <Geometry x:Key="Icon.Delete">M9,3V4H4V6H5V19A2,2 0 0,0 7,21H17A2,2 0 0,0 19,19V6H20V4H15V3H9M7,6H17V19H7V6M9,8V17H11V8H9M13,8V17H15V8H13Z</Geometry>
            <Geometry x:Key="Icon.File">M13,9H18.5L13,3.5V9M6,2H14L20,8V20A2,2 0 0,1 18,22H6C4.89,22 4,21.1 4,20V4C4,2.89 4.89,2 6,2M15,18V16H6V18H15M18,14V12H6V14H18Z</Geometry>
            <Geometry x:Key="Icon.Settings">M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11.03L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.97 19.05,5.05L16.56,6.05C16.04,5.66 15.47,5.32 14.87,5.07L14.49,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.51,2.42L9.13,5.07C8.52,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.97 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11.03C4.53,11.34 4.5,11.67 4.5,12C4.5,11.67 4.47,11.34 4.43,11.03L2.32,9.37C2.13,9.22 2.08,8.95 2.2,8.73L4.2,5.27C4.32,5.05 4.59,4.97 4.81,5.05L7.3,6.05C7.82,5.66 8.39,5.32 8.99,5.07L9.37,2.42C9.4,2.18 9.61,2 9.86,2H13.86C14.11,2 14.32,2.18 14.35,2.42L14.73,5.07C15.34,5.32 15.9,5.66 16.42,6.05L18.91,5.05C19.13,4.97 19.4,5.05 19.52,5.27L21.52,8.73C21.65,8.95 21.59,9.22 21.4,9.37L19.29,11.03C19.33,11.34 19.36,11.67 19.36,12C19.36,12.33 19.33,12.65 19.29,12.97L21.4,14.63C21.59,14.78 21.64,15.05 21.52,15.27L19.52,18.73C19.4,18.95 19.13,19.03 18.91,18.95L16.42,17.95C15.9,18.34 15.34,18.68 14.73,18.93L14.35,21.58C14.32,21.82 14.11,22 13.86,22H9.86C9.61,22 9.4,21.82 9.37,21.58L8.99,18.93C8.39,18.68 7.82,18.34 7.3,17.95L4.81,18.95C4.59,19.03 4.32,18.95 4.2,18.73L2.2,15.27C2.08,15.05 2.13,14.78 2.32,14.63L4.43,12.97Z</Geometry>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="{DynamicResource BackgroundDarkBrush}" CornerRadius="12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="Auto"/> <!-- Hero -->
                <RowDefinition Height="*"/>    <!-- Body -->
                <RowDefinition Height="Auto"/> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- Window Header -->
            <Grid Grid.Row="0" Margin="16,16,16,8">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Path Data="{StaticResource Icon.Broom}" Fill="{DynamicResource CyanBrush}" Width="18" Height="18" Stretch="Uniform"/>
                    <TextBlock Text="{DynamicResource Lang.Action.DiskCleanup}" FontSize="14" FontWeight="SemiBold" 
                               Foreground="{DynamicResource TextWhiteBrush}" Margin="12,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="⚙" Style="{DynamicResource IconButtonStyle}" Width="32" Height="32" Click="Settings_Click" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <Button Content="─" Style="{DynamicResource IconButtonStyle}" Width="32" Height="32" Click="MinimizeButton_Click" Foreground="{DynamicResource TextSecondaryBrush}" Margin="4,0"/>
                    <Button Content="✕" Style="{DynamicResource IconButtonStyle}" Width="32" Height="32" Click="CloseButton_Click" Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </Grid>

            <!-- Hero Section -->
            <Border Grid.Row="1" Margin="16,8" Padding="24" Background="{DynamicResource SurfaceDarkBrush}" CornerRadius="8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="{DynamicResource Lang.DiskCleanup.TotalSize}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="Medium"/>
                        <TextBlock x:Name="TotalSizeText" Text="0.00 MB" FontSize="36" FontWeight="SemiBold" Foreground="{DynamicResource CyanBrush}" Margin="0,4,0,0"/>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock x:Name="FileCountText" Text="0 files selected" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                            <TextBlock Text=" | " Foreground="{DynamicResource BorderBrush}" Margin="8,0"/>
                            <TextBlock x:Name="CategoryCountText" Text="0 categories selected" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                        </StackPanel>

                        <!-- Modern Toggles -->
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <CheckBox x:Name="RecycleQuickToggle" Content="{DynamicResource Lang.DiskCleanup.IncludeRecycle}" 
                                      FontSize="12" Foreground="{DynamicResource TextWhiteBrush}"
                                      IsChecked="True" Checked="RecycleQuickToggle_Changed" Unchecked="RecycleQuickToggle_Changed"
                                      VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal">
                        <Button x:Name="ScanButton" Content="{DynamicResource Lang.DiskCleanup.Scan}" Style="{DynamicResource SecondaryButtonStyle}" 
                                Click="Rescan_Click" Margin="0,0,12,0" Width="100" Height="36"/>
                        <Button x:Name="CleanButton" Content="{DynamicResource Lang.DiskCleanup.CleanNow}" Style="{DynamicResource PrimaryButtonStyle}" 
                                Click="CleanNow_Click" Width="120" Height="36" Background="{DynamicResource CyanBrush}" FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main Content Area (3 Columns) -->
            <Grid Grid.Row="2" Margin="16,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/> <!-- Left: Categories -->
                    <ColumnDefinition Width="*"/>   <!-- Center: Explorer List -->
                    <ColumnDefinition Width="280"/> <!-- Right: Preview Pane -->
                </Grid.ColumnDefinitions>

                <!-- Column 0: Categories -->
                <DockPanel Margin="0,0,12,0">
                    <TextBlock DockPanel.Dock="Top" Text="{DynamicResource Lang.DiskCleanup.Categories}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" FontWeight="Bold" Margin="4,0,0,8"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="CategoriesPanel">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,6" Padding="10" CornerRadius="8" Background="{DynamicResource CardDarkBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Cursor="Hand" MouseLeftButtonUp="CategoryCard_Click">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,10,0" Checked="Category_Checked" Unchecked="Category_Unchecked"/>
                                            
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="Medium" Foreground="{DynamicResource TextWhiteBrush}"/>
                                                <TextBlock Text="{Binding Description}" FontSize="9" Foreground="{DynamicResource TextMutedBrush}" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>

                                            <TextBlock Grid.Column="2" Text="{Binding EstimatedSizeStr}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource CyanBrush}" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>

                <!-- Column 1: Explorer-style File List -->
                <Border Grid.Column="1" Background="{DynamicResource SurfaceDarkBrush}" CornerRadius="8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,12,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="12">
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource Icon.File}" Fill="{DynamicResource TextSecondaryBrush}" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="DetailsTitle" Text="{DynamicResource Lang.DiskCleanup.Details}" Foreground="{DynamicResource TextWhiteBrush}" FontSize="12" FontWeight="SemiBold" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock x:Name="DetailsCount" Text="0 items" HorizontalAlignment="Right" Foreground="{DynamicResource TextMutedBrush}" FontSize="11" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <ListView x:Name="FilesListView" Grid.Row="1" Background="Transparent" BorderThickness="0" 
                                  SelectionChanged="FilesListView_SelectionChanged" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                             <ListView.View>
                                <GridView>
                                    <GridViewColumn Width="30">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsChecked}" VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    
                                    <GridViewColumn Header="{DynamicResource Lang.DiskCleanup.Name}" Width="250">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Path Data="{StaticResource Icon.File}" Fill="{DynamicResource CyanBrush}" Width="14" Height="14" Margin="0,0,8,0" Stretch="Uniform"/>
                                                    <TextBlock Text="{Binding FileName}" Foreground="{DynamicResource TextWhiteBrush}" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    
                                    <GridViewColumn Header="{DynamicResource Lang.DiskCleanup.Size}" Width="80">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding SizeStr}" Foreground="{DynamicResource CyanBrush}" FontWeight="Medium"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="{DynamicResource Lang.DiskCleanup.Modified}" Width="120">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding DateModified, StringFormat='dd/MM/yyyy'}" Foreground="{DynamicResource TextMutedBrush}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </Border>

                <!-- Column 2: Preview Pane -->
                <Border Grid.Column="2" Background="{DynamicResource SurfaceDarkBrush}" CornerRadius="8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="12">
                            <TextBlock Text="{DynamicResource Lang.DiskCleanup.Preview}" Foreground="{DynamicResource TextWhiteBrush}" FontSize="12" FontWeight="SemiBold"/>
                        </Border>

                        <!-- Preview Image Content -->
                        <Grid Grid.Row="1" Margin="12">
                            <Border x:Name="NoPreviewContainer" Visibility="Visible">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Opacity="0.5">
                                    <Path Data="{StaticResource Icon.File}" Fill="{DynamicResource TextMutedBrush}" Width="48" Height="48" Stretch="Uniform" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{DynamicResource Lang.DiskCleanup.NoPreview}" Foreground="{DynamicResource TextMutedBrush}" FontSize="11" Margin="0,12,0,0" TextAlignment="Center" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            
                            <Image x:Name="PreviewImage" Stretch="Uniform" Visibility="Collapsed" RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Grid>

                        <!-- File Info -->
                        <Border Grid.Row="2" Background="{DynamicResource BackgroundDarkBrush}" CornerRadius="0,0,8,8" Padding="16" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
                            <StackPanel>
                                <TextBlock x:Name="PreviewFileName" Text="..." FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextWhiteBrush}" TextWrapping="Wrap"/>
                                <TextBlock x:Name="PreviewFileSize" Text="..." FontSize="10" Foreground="{DynamicResource CyanBrush}" Margin="0,4,0,0"/>
                                <TextBlock x:Name="PreviewFileType" Text="..." FontSize="9" Foreground="{DynamicResource TextMutedBrush}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- Status Footer -->
            <Grid Grid.Row="3" Margin="16,8,16,16">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{DynamicResource Lang.DiskCleanup.Select}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center"/>
                    <Button Content="{DynamicResource Lang.DiskCleanup.All}" Margin="4,0" Style="{DynamicResource TextButtonStyle}" Click="CheckAll_Click"/>
                    <Button Content="{DynamicResource Lang.DiskCleanup.None}" Margin="4,0" Style="{DynamicResource TextButtonStyle}" Click="CheckNone_Click"/>
                    <Button Content="{DynamicResource Lang.DiskCleanup.Default}" Margin="4,0" Style="{DynamicResource TextButtonStyle}" Click="CheckDefault_Click"/>
                </StackPanel>

                <TextBlock x:Name="StatusText" Text="Ready" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="12"/>
            </Grid>

            <!-- Confirmation Overlay -->
             <Grid x:Name="ConfirmationOverlay" Grid.RowSpan="4" Panel.ZIndex="1000" Visibility="Collapsed">
                <Border Background="{DynamicResource OverlayDark}"/>
                <Border Background="{DynamicResource CardDarkBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Width="400" Height="220" CornerRadius="8" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Grid Margin="24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Text="{DynamicResource Lang.DiskCleanup.ConfirmTitle}" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextWhiteBrush}"/>
                        <TextBlock Grid.Row="1" x:Name="ConfirmMessageText" Text="{DynamicResource Lang.DiskCleanup.ConfirmMsg}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14" TextWrapping="Wrap" Margin="0,16,0,0"/>
                        
                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="{DynamicResource Lang.Common.Cancel}" Style="{DynamicResource SecondaryButtonStyle}" Click="CancelCleanup_Click" Width="80" Height="32" Margin="0,0,12,0"/>
                            <Button Content="{DynamicResource Lang.DiskCleanup.CleanNow}" Style="{DynamicResource PrimaryButtonStyle}" Click="ConfirmCleanNow_Click" Width="100" Height="32"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
