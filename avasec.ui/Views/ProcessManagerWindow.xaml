<Window x:Class="AVASec.UI.Views.ProcessManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quản lý Tiến trình / Process Manager" Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" GlassFrameThickness="0" CornerRadius="12"/>
    </WindowChrome.WindowChrome>

    <Border Background="{StaticResource MainBackgroundGradient}" CornerRadius="12" BorderBrush="{StaticResource BorderGlowBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Title Bar -->
                <RowDefinition Height="Auto"/>  <!-- Content Header -->
                <RowDefinition Height="*"/>     <!-- Process List -->
                <RowDefinition Height="Auto"/>  <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="{StaticResource DarkSurfaceBrush}" 
                    CornerRadius="12,12,0,0" MouseLeftButtonDown="TitleBar_MouseDown" Height="40">
                <Grid Margin="15,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <Button Click="Back_Click" Style="{StaticResource IconButtonStyle}" ToolTip="Back">
                        <TextBlock Text="←" FontSize="18" Margin="0,-2,0,0"/>
                    </Button>
                    
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="⚡" FontSize="16" Margin="0,0,10,0"/>
                        <TextBlock Text="Process Manager" Style="{StaticResource Heading2Style}" Margin="0" FontSize="16"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="👤" x:Name="UserButton" Style="{StaticResource IconButtonStyle}" Width="36" Height="36" Click="UserButton_Click" Foreground="White" ToolTip="Login / Đăng nhập" WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button Content="💬" x:Name="ChatToggleButton" Style="{StaticResource IconButtonStyle}" Width="36" Height="36" Click="ChatToggle_Click" Foreground="White" Margin="0,0,5,0" ToolTip="Support Chat (Dashboard) / Hỗ trợ Chat" WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button Content="⚙" Style="{StaticResource IconButtonStyle}" Width="36" Height="36" Click="Settings_Click" Foreground="White" WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button Content="☰" Style="{StaticResource IconButtonStyle}" Width="36" Height="36" Click="Toolbox_Click" Foreground="White" WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button Content="─" Style="{StaticResource IconButtonStyle}" Width="36" Height="36" Click="MinimizeButton_Click" Foreground="White" ToolTip="Minimize to Taskbar / Thu nhỏ xuống thanh tác vụ" WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button Content="➘" Style="{StaticResource IconButtonStyle}" Width="36" Height="36" Click="TrayButton_Click" Foreground="White" ToolTip="Hide / Ẩn" WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button Content="✕" Style="{StaticResource IconButtonStyle}" Width="36" Height="36" Click="CloseButton_Click" Foreground="White" ToolTip="Close / Đóng" WindowChrome.IsHitTestVisibleInChrome="True"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content Header -->
            <Border Grid.Row="1" Background="Transparent" Padding="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Quản lý Tiến trình / Process Manager Details" 
                                   FontSize="18" FontWeight="Bold" 
                                   Foreground="{StaticResource TextBrush}"/>
                        <TextBlock Text="Xem và tắt các ứng dụng đang chạy / View running apps and end task" 
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,5,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="🔄 Refresh" Click="Refresh_Click" Padding="15,5" 
                            Style="{StaticResource SecondaryButtonStyle}" Foreground="{StaticResource TextBrush}"/>
                </Grid>
            </Border>

            <ListView x:Name="ProcessListView" Grid.Row="2" Margin="20" 
                      Background="{StaticResource SurfaceBrush}" 
                      BorderThickness="0" 
                      SelectionMode="Single"
                      Foreground="{StaticResource TextBrush}">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding" Value="5"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <Border x:Name="border" Background="Transparent" Padding="5" CornerRadius="4">
                                        <GridViewRowPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="{DynamicResource SelectedItemBgBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBlueBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="{DynamicResource HoverBgBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="ID" Width="80" DisplayMemberBinding="{Binding Id}"/>
                        <GridViewColumn Header="Name" Width="200" DisplayMemberBinding="{Binding Name}"/>
                        <GridViewColumn Header="Title" Width="300" DisplayMemberBinding="{Binding Title}"/>
                        <GridViewColumn Header="Memory" Width="100" DisplayMemberBinding="{Binding MemoryUsageFormatted}"/>
                    </GridView>
                </ListView.View>
            </ListView>

            <!-- Footer -->
            <Border Grid.Row="3" Background="{StaticResource SurfaceBrush}" Padding="15" CornerRadius="0,0,12,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock x:Name="StatusText" VerticalAlignment="Center" Margin="0,0,15,0" 
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <Button Content="Kết thúc / End Task" Width="150" Padding="10,5" 
                            Background="{StaticResource DangerBrush}" Foreground="White" BorderThickness="0"
                            Click="EndTask_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
