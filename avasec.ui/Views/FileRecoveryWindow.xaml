<Window x:Class="AVASec.UI.Views.FileRecoveryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="File Recovery" Height="650" Width="950"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Loaded="Window_Loaded">

    <Window.Resources>
        <Style x:Key="DriveItemStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💾" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#EFF6FF"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AccentBlueBrush}"/>
                                <Setter Property="Foreground" Value="#0F172A"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FileListHeader" TargetType="GridViewColumnHeader">
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Border Background="#FFFFFF" CornerRadius="16" BorderBrush="#E2E8F0" BorderThickness="1.5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="Auto"/> <!-- Controls -->
                <RowDefinition Height="*"/>    <!-- File List -->
                <RowDefinition Height="Auto"/> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Padding="25" Background="#F8FAFC" CornerRadius="16,16,0,0" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="40" Height="40" Background="{DynamicResource AccentBlueBrush}" CornerRadius="10" Margin="0,0,15,0">
                            <TextBlock Text="♻️" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="22"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource Lang.Recovery.Title}" FontSize="20" FontWeight="Bold" Foreground="#0F172A"/>
                            <TextBlock Text="Professional Data Recovery Tool" FontSize="12" Foreground="#64748B"/>
                        </StackPanel>
                    </StackPanel>
                    
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top" 
                            Width="30" Height="30" Background="Transparent" BorderThickness="0" Foreground="#64748B" FontSize="16" FontWeight="Bold"
                            Click="CloseButton_Click" WindowChrome.IsHitTestVisibleInChrome="True">
                             <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="15">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#E2E8F0"/>
                                            <Setter Property="Foreground" Value="#EF4444"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Controls Area -->
            <StackPanel Grid.Row="1" Margin="25,20,25,0">
                <TextBlock Text="{DynamicResource Lang.Recovery.SelectDrive}" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal">
                    <ItemsControl x:Name="DrivesList" ItemsSource="{Binding Drives}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <RadioButton GroupName="Drives" Content="{Binding Name}" Tag="{Binding Name}" 
                                             Style="{StaticResource DriveItemStyle}" Checked="Drive_Checked" IsChecked="{Binding IsReady}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    
                    <Button x:Name="BtnScan" Content="{DynamicResource Lang.Recovery.ScanBtn}" Click="ScanButton_Click"
                            Width="150" Height="40" Style="{DynamicResource PrimaryButtonStyle}" Margin="20,0,0,0"/>
                </StackPanel>

                <!-- Progress Bar -->
                <Grid Margin="0,20,0,0" x:Name="ProgressArea" Visibility="Collapsed">
                    <ProgressBar x:Name="ScanProgress" Height="6" Background="#F1F5F9" BorderThickness="0" Foreground="{DynamicResource AccentBlueBrush}"/>
                    <TextBlock x:Name="StatusText" Text="{DynamicResource Lang.Recovery.Scanning}" Margin="0,10,0,0" Foreground="#64748B" FontSize="12"/>
                </Grid>
            </StackPanel>

            <!-- File List -->
            <Border Grid.Row="2" Margin="25,20,25,20" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8">
                <ListView x:Name="FilesListView" BorderThickness="0" Background="White">
                    <ListView.View>
                        <GridView ColumnHeaderContainerStyle="{StaticResource FileListHeader}">
                            <GridViewColumn Width="50">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="File Name" Width="250" DisplayMemberBinding="{Binding FileName}"/>
                            <GridViewColumn Header="{DynamicResource Lang.Recovery.Path}" Width="300" DisplayMemberBinding="{Binding OriginalPath}"/>
                            <GridViewColumn Header="{DynamicResource Lang.Recovery.Size}" Width="100" DisplayMemberBinding="{Binding Size}"/>
                            <GridViewColumn Header="{DynamicResource Lang.Recovery.Date}" Width="150" DisplayMemberBinding="{Binding DateDeleted, StringFormat=d}"/>
                            <GridViewColumn Header="{DynamicResource Lang.Recovery.Status}" Width="100" DisplayMemberBinding="{Binding Status}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Border>

            <!-- Footer -->
            <Border Grid.Row="3" Padding="25" Background="#F8FAFC" CornerRadius="0,0,16,16" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{DynamicResource Lang.Recovery.FoundFiles}" Foreground="#64748B"/>
                        <TextBlock x:Name="TxtCount" Text="0" FontWeight="Bold" Margin="5,0,0,0" Foreground="#0F172A"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <StackPanel Orientation="Horizontal" Margin="0,0,20,0" VerticalAlignment="Center">
                             <TextBlock Text="{DynamicResource Lang.Recovery.Output}" VerticalAlignment="Center" Foreground="#64748B" Margin="0,0,10,0"/>
                             <TextBox x:Name="TxtOutputPath" Width="200" Height="30" Padding="5" VerticalContentAlignment="Center" IsReadOnly="True" Background="#F1F5F9" BorderBrush="#E2E8F0"/>
                             <Button Content="..." Width="30" Height="30" Click="BrowseButton_Click" Background="#F1F5F9" BorderBrush="#E2E8F0" Margin="5,0,0,0"/>
                        </StackPanel>

                        <Button Content="Preview" Width="100" Height="40" Margin="0,0,10,0" Background="Transparent" BorderBrush="#CBD5E1" BorderThickness="1" Foreground="#475569"
                                Style="{DynamicResource IconButtonStyle}"/>
                        <Button x:Name="BtnRecover" Content="{DynamicResource Lang.Recovery.RecoverBtn}" Click="RecoverButton_Click"
                                Width="180" Height="40" Style="{DynamicResource PrimaryButtonStyle}" IsEnabled="False"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
    
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="60" ResizeBorderThickness="5" GlassFrameThickness="0" CornerRadius="16"/>
    </WindowChrome.WindowChrome>
</Window>
