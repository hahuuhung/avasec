<Window x:Class="AVASec.UI.Views.ChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:AVASec.UI.Controls"
        Title="AVA Security Support Chat" 
        Height="550" Width="520"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="Manual">
    
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="60" GlassFrameThickness="0" CornerRadius="12"/>
    </WindowChrome.WindowChrome>

    <Border Background="Transparent" Padding="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Opacity="0.3" ShadowDepth="2"/>
        </Border.Effect>
        <Border x:Name="MainContainer" CornerRadius="12" Background="Transparent" />
    </Border>
</Window>
