<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- =========================================== -->
    <!-- AVA Security Control Styles -->
    <!-- Các Kiểu Điều khiển AVA Security -->
    <!-- =========================================== -->

    <!-- Toggle Switch Style for CheckBox -->
    <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="Background" Value="#2D3A4F"/>
        <Setter Property="BorderBrush" Value="#2D3A4F"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Switch Track -->
                        <Border x:Name="Track" Grid.Column="0"
                                Width="40" Height="20"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                BorderThickness="1"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <!-- Switch Thumb -->
                            <Ellipse x:Name="Thumb" 
                                     Width="14" Height="14" 
                                     Fill="White"
                                     HorizontalAlignment="Left"
                                     Margin="3,0,0,0"/>
                        </Border>
                        
                        <ContentPresenter Grid.Column="1" 
                                          VerticalAlignment="Center" 
                                          Margin="10,0,0,0"
                                          RecognizesAccessKey="True"/>
                    </Grid>
                    
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Track" Property="Background" Value="{DynamicResource AccentBlueBrush}"/>
                            <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource AccentBlueBrush}"/>
                            <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                            <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
