<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Semantic Theme Brushes - LIGHT MODE / Cọ Chủ đề - CHẾ ĐỘ SÁNG -->
    
    <!-- Backgrounds -->
    <SolidColorBrush x:Key="ThemeBackgroundBrush" Color="#F5F6FA"/>
    <SolidColorBrush x:Key="ThemeSurfaceBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ThemeSidebarBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ThemeContentBrush" Color="#F5F6FA"/>
    <SolidColorBrush x:Key="ThemeCardBrush" Color="#FFFFFF"/>
    
    <!-- Text -->
    <SolidColorBrush x:Key="ThemeTextPrimaryBrush" Color="#333333"/>
    <SolidColorBrush x:Key="ThemeTextSecondaryBrush" Color="#666666"/>
    <SolidColorBrush x:Key="ThemeTextMutedBrush" Color="#999999"/>
    <SolidColorBrush x:Key="ThemeTextReverseBrush" Color="#FFFFFF"/>
    
    <!-- Borders -->
    <SolidColorBrush x:Key="ThemeBorderBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="ThemeBorderLightBrush" Color="#EEEEEE"/>
    
    <!-- Gradients -->
    <LinearGradientBrush x:Key="ThemeHeaderGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#2196F3" Offset="0"/>
        <GradientStop Color="#64B5F6" Offset="1"/>
    </LinearGradientBrush>

    <!-- Compatibility Redirections -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#F5F6FA"/>
    <SolidColorBrush x:Key="LightBgBrush" Color="#F5F6FA"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="CardBgBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SidebarBgBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ContentBgBrush" Color="#F5F6FA"/>
    
    <SolidColorBrush x:Key="TextBrush" Color="#333333"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#333333"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#666666"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="#999999"/>
    
    <SolidColorBrush x:Key="BorderBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="BorderLightBrush" Color="#EEEEEE"/>
    <SolidColorBrush x:Key="BorderDarkBrush" Color="#BDBDBD"/>
    
    <SolidColorBrush x:Key="SelectedItemBgBrush" Color="#E8F4FC"/>
    <SolidColorBrush x:Key="HoverBgBrush" Color="#F0F7FC"/>
    
    <SolidColorBrush x:Key="BackgroundDarkBrush" Color="#F5F6FA"/>
    <SolidColorBrush x:Key="SurfaceDarkBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="CardDarkBrush" Color="#FFFFFF"/>

    <LinearGradientBrush x:Key="DashboardHeaderGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#2196F3" Offset="0"/>
        <GradientStop Color="#64B5F6" Offset="1"/>
    </LinearGradientBrush>
    
    <StaticResource x:Key="HeaderGradient" ResourceKey="DashboardHeaderGradient"/>

</ResourceDictionary>
