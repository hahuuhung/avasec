<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- =========================================== -->
    <!-- AVA Security Animation System - Professional Transitions -->
    <!-- Hệ thống Hoạt ảnh AVA Security - Chuyển tiếp Chuyên nghiệp -->
    <!-- =========================================== -->
    
    <!-- =========================================== -->
    <!-- Easing Functions / Hàm Easing -->
    <!-- =========================================== -->
    
    <!-- Smooth Ease Out / Easing Mượt Giảm dần -->
    <QuadraticEase x:Key="EaseOutQuad" EasingMode="EaseOut"/>
    <CubicEase x:Key="EaseOutCubic" EasingMode="EaseOut"/>
    <QuarticEase x:Key="EaseOutQuart" EasingMode="EaseOut"/>
    
    <!-- Smooth Ease In / Easing Mượt Tăng dần -->
    <QuadraticEase x:Key="EaseInQuad" EasingMode="EaseIn"/>
    <CubicEase x:Key="EaseInCubic" EasingMode="EaseIn"/>
    
    <!-- Ease In Out / Easing Mượt Hai chiều -->
    <QuadraticEase x:Key="EaseInOutQuad" EasingMode="EaseInOut"/>
    <CubicEase x:Key="EaseInOutCubic" EasingMode="EaseInOut"/>
    
    <!-- Bounce / Nảy -->
    <BounceEase x:Key="BounceEase" EasingMode="EaseOut" Bounces="2" Bounciness="2"/>
    
    <!--Elastic / Đàn hồi -->
    <ElasticEase x:Key="ElasticEase" EasingMode="EaseOut" Oscillations="1" Springiness="3"/>
    
    <!-- =========================================== -->
    <!-- Fade Animations / Hoạt ảnh Làm mờ -->
    <!-- =========================================== -->
    
    <!-- Fade In / Làm hiện -->
    <Storyboard x:Key="FadeInAnimation">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         From="0" To="1" Duration="0:0:0.3"
                         EasingFunction="{StaticResource EaseOutQuad}"/>
    </Storyboard>
    
    <!-- Fade Out / Làm mờ -->
    <Storyboard x:Key="FadeOutAnimation">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         From="1" To="0" Duration="0:0:0.2"
                         EasingFunction="{StaticResource EaseInQuad}"/>
    </Storyboard>
    
    <!-- Quick Fade In / Làm hiện Nhanh -->
    <Storyboard x:Key="QuickFadeIn">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         From="0" To="1" Duration="0:0:0.15"/>
    </Storyboard>
    
    <!-- =========================================== -->
    <!-- Slide Animations / Hoạt ảnh Trượt -->
    <!-- =========================================== -->
    
    <!-- Slide In From Left / Trượt vào từ Trái -->
    <Storyboard x:Key="SlideInFromLeft">
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                         From="-100" To="0" Duration="0:0:0.3"
                         EasingFunction="{StaticResource EaseOutCubic}"/>
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         From="0" To="1" Duration="0:0:0.3"/>
    </Storyboard>
    
    <!-- Slide In From Right / Trượt vào từ Phải -->
    <Storyboard x:Key="SlideInFromRight">
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                         From="100" To="0" Duration="0:0:0.3"
                         EasingFunction="{StaticResource EaseOutCubic}"/>
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         From="0" To="1" Duration="0:0:0.3"/>
    </Storyboard>
    
    <!-- Slide In From Top / Trượt vào từ Trên -->
    <Storyboard x:Key="SlideInFromTop">
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                         From="-50" To="0" Duration="0:0:0.3"
                         EasingFunction="{StaticResource EaseOutCubic}"/>
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         From="0" To="1" Duration="0:0:0.3"/>
    </Storyboard>
    
    <!-- Slide In From Bottom / Trượt vào từ Dưới -->
    <Storyboard x:Key="SlideInFromBottom">
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                         From="50" To="0" Duration="0:0:0.3"
                         EasingFunction="{StaticResource EaseOutCubic}"/>
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         From="0" To="1" Duration="0:0:0.3"/>
    </Storyboard>
    
    <!-- =========================================== -->
    <!-- Scale Animations / Hoạt ảnh Thu phóng -->
    <!-- =========================================== -->
    
    <!-- Scale Up / Phóng to -->
    <Storyboard x:Key="ScaleUp">
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                         From="0.95" To="1" Duration="0:0:0.2"
                         EasingFunction="{StaticResource EaseOutQuad}"/>
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                         From="0.95" To="1" Duration="0:0:0.2"
                         EasingFunction="{StaticResource EaseOutQuad}"/>
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         From="0" To="1" Duration="0:0:0.2"/>
    </Storyboard>
    
    <!-- Pulse / Nhấp nháy -->
    <Storyboard x:Key="PulseAnimation" AutoReverse="True" RepeatBehavior="Forever">
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                         From="1" To="1.05" Duration="0:0:1"
                         EasingFunction="{StaticResource EaseInOutQuad}"/>
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                         From="1" To="1.05" Duration="0:0:1"
                         EasingFunction="{StaticResource EaseInOutQuad}"/>
    </Storyboard>
    
    <!-- =========================================== -->
    <!-- Rotation Animations / Hoạt ảnh Xoay -->
    <!-- =========================================== -->
    
    <!-- Spin / Quay tròn -->
    <Storyboard x:Key="SpinAnimation" RepeatBehavior="Forever">
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                         From="0" To="360" Duration="0:0:1"/>
    </Storyboard>
    
    <!-- Spin Slow / Quay chậm -->
    <Storyboard x:Key="SpinSlowAnimation" RepeatBehavior="Forever">
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                         From="0" To="360" Duration="0:0:2"/>
    </Storyboard>
    
    <!-- =========================================== -->
    <!-- Shake Animation / Hoạt ảnh Rung -->
    <!-- =========================================== -->
    
    <!-- Shake for Error / Rung cho Lỗi -->
    <Storyboard x:Key="ShakeAnimation">
        <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)">
            <LinearDoubleKeyFrame Value="0" KeyTime="0:0:0"/>
            <LinearDoubleKeyFrame Value="-10" KeyTime="0:0:0.05"/>
            <LinearDoubleKeyFrame Value="10" KeyTime="0:0:0.1"/>
            <LinearDoubleKeyFrame Value="-10" KeyTime="0:0:0.15"/>
            <LinearDoubleKeyFrame Value="10" KeyTime="0:0:0.2"/>
            <LinearDoubleKeyFrame Value="0" KeyTime="0:0:0.25"/>
        </DoubleAnimationUsingKeyFrames>
    </Storyboard>
    
</ResourceDictionary>
