<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- =========================================== -->
    <!-- AVA Security Color System - Glary Utilities Light Theme -->
    <!-- Hệ thống Màu sắc AVA Security - Giao diện Sáng Glary Utilities -->
    <!-- =========================================== -->

    <!-- Primary Background Colors / Màu Nền Chính -->
    <Color x:Key="LightBgColor">#F5F6FA</Color>
    <Color x:Key="WhiteColor">#FFFFFF</Color>
    <Color x:Key="SidebarBgColor">#FFFFFF</Color>
    <Color x:Key="ContentBgColor">#F5F6FA</Color>
    <Color x:Key="CardBgColor">#FFFFFF</Color>
    
    <!-- Professional Dark Theme Colors - Palette / Màu Palette Theme Tối Chuyên nghiệp -->
    <Color x:Key="BackgroundDarkColor">#0F172A</Color>
    <Color x:Key="SurfaceDarkColor">#1E293B</Color>
    <Color x:Key="CardDarkColor">#1E293B</Color>
    <Color x:Key="CyanColor">#06B6D4</Color>
    <Color x:Key="NeonCyanColor">#06B6D4</Color>
    <Color x:Key="AccentGoldColor">#FFD700</Color>
    
    <!-- Accent Colors / Màu Nhấn -->
    <Color x:Key="AccentBlueColor">#2196F3</Color>
    <Color x:Key="AccentBlueLightColor">#64B5F6</Color>
    <Color x:Key="AccentBlueDarkColor">#1976D2</Color>
    <Color x:Key="SelectedItemBgColor">#E8F4FC</Color>
    <Color x:Key="HoverBgColor">#F0F7FC</Color>
    <Color x:Key="OrangeButtonColor">#FF6B35</Color>
    <Color x:Key="GreenColor">#4CAF50</Color>
    
    <!-- Text Colors / Màu Chữ -->
    <Color x:Key="TextPrimaryColor">#333333</Color>
    <Color x:Key="TextSecondaryColor">#666666</Color>
    <Color x:Key="TextMutedColor">#999999</Color>
    <Color x:Key="TextWhiteColor">#FFFFFF</Color>
    <Color x:Key="TextBlueColor">#2196F3</Color>
    
    <!-- Border Colors / Màu Viền -->
    <Color x:Key="BorderColor">#E0E0E0</Color>
    <Color x:Key="BorderLightColor">#EEEEEE</Color>
    <Color x:Key="BorderDarkColor">#BDBDBD</Color>
    
    <!-- Status Colors / Màu Trạng thái -->
    <Color x:Key="SuccessColor">#4CAF50</Color>
    <Color x:Key="WarningColor">#FF9800</Color>
    <Color x:Key="ErrorColor">#F44336</Color>
    <Color x:Key="InfoColor">#2196F3</Color>
    
    <!-- =========================================== -->
    <!-- SolidColorBrushes / Cọ Màu Đặc -->
    <!-- =========================================== -->
    
    <!-- Background Brushes -->
    <SolidColorBrush x:Key="LightBgBrush" Color="{StaticResource LightBgColor}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource WhiteColor}"/>
    <SolidColorBrush x:Key="SidebarBgBrush" Color="{StaticResource SidebarBgColor}"/>
    <SolidColorBrush x:Key="ContentBgBrush" Color="{StaticResource ContentBgColor}"/>
    <SolidColorBrush x:Key="CardBgBrush" Color="{StaticResource CardBgColor}"/>
    <SolidColorBrush x:Key="SelectedItemBgBrush" Color="{StaticResource SelectedItemBgColor}"/>
    <SolidColorBrush x:Key="HoverBgBrush" Color="{StaticResource HoverBgColor}"/>
    
    <!-- Accent Brushes -->
    <SolidColorBrush x:Key="AccentBlueBrush" Color="{StaticResource AccentBlueColor}"/>
    <SolidColorBrush x:Key="AccentBlueLightBrush" Color="{StaticResource AccentBlueLightColor}"/>
    <SolidColorBrush x:Key="AccentBlueDarkBrush" Color="{StaticResource AccentBlueDarkColor}"/>
    <SolidColorBrush x:Key="OrangeButtonBrush" Color="{StaticResource OrangeButtonColor}"/>
    <SolidColorBrush x:Key="GreenBrush" Color="{StaticResource GreenColor}"/>
    
    <!-- Text Brushes -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="TextWhiteBrush" Color="{StaticResource TextWhiteColor}"/>
    <SolidColorBrush x:Key="TextBlueBrush" Color="{StaticResource TextBlueColor}"/>
    
    <!-- Border Brushes -->
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="BorderLightBrush" Color="{StaticResource BorderLightColor}"/>
    <SolidColorBrush x:Key="BorderDarkBrush" Color="{StaticResource BorderDarkColor}"/>
    
    <!-- Status Brushes -->
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>

    <!-- Professional Brushes -->
    <SolidColorBrush x:Key="BackgroundDarkBrush" Color="{StaticResource BackgroundDarkColor}"/>
    <SolidColorBrush x:Key="SurfaceDarkBrush" Color="{StaticResource SurfaceDarkColor}"/>
    <SolidColorBrush x:Key="CardDarkBrush" Color="{StaticResource CardDarkColor}"/>
    <SolidColorBrush x:Key="CyanBrush" Color="{StaticResource CyanColor}"/>
    <SolidColorBrush x:Key="NeonCyanBrush" Color="{StaticResource NeonCyanColor}"/>
    <SolidColorBrush x:Key="AccentGoldBrush" Color="{StaticResource AccentGoldColor}"/>
    <SolidColorBrush x:Key="CyanGlow" Color="{StaticResource CyanColor}" Opacity="0.3"/>
    <SolidColorBrush x:Key="AccentWarningBrush" Color="{StaticResource WarningColor}"/>
    
    <!-- =========================================== -->
    <!-- Gradient Brushes / Cọ Gradient -->
    <!-- =========================================== -->
    

    
    <LinearGradientBrush x:Key="MainBackgroundGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#F5F6FA" Offset="0"/>
        <GradientStop Color="#FFFFFF" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="SidebarGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFFFFF" Offset="0"/>
        <GradientStop Color="#F5F6FA" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="ButtonGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#2196F3" Offset="0"/>
        <GradientStop Color="#1976D2" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="OrangeGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#FF6B35" Offset="0"/>
        <GradientStop Color="#FF8A50" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="SuccessGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#4CAF50" Offset="0"/>
        <GradientStop Color="#66BB6A" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="DangerGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#F44336" Offset="0"/>
        <GradientStop Color="#EF5350" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="PrimaryGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#2196F3" Offset="0"/>
        <GradientStop Color="#4CAF50" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- =========================================== -->
    <!-- Enhanced Modern Gradients / Gradient Hiện đại Nâng cao -->
    <!-- =========================================== -->
    
    <!-- Subtle Card Gradient / Gradient Thẻ Tinh tế -->
    <LinearGradientBrush x:Key="CardGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFFFFF" Offset="0"/>
        <GradientStop Color="#FAFBFC" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- Glass Overlay for Glassmorphism / Lớp phủ Kính cho Glassmorphism -->
    <SolidColorBrush x:Key="GlassOverlay" Color="#FFFFFF" Opacity="0.15"/>
    <SolidColorBrush x:Key="GlassHighlight" Color="#FFFFFF" Opacity="0.3"/>
    <SolidColorBrush x:Key="GlassBackground" Color="#FFFFFF" Opacity="0.7"/>
    
    <!-- Elevated Surface Colors / Màu Bề mặt Nổi -->
    <Color x:Key="SurfaceElevatedColor">#FFFFFF</Color>
    <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="{StaticResource SurfaceElevatedColor}"/>
    
    <!-- Hover State Colors / Màu Trạng thái Hover -->
    <Color x:Key="ButtonHoverColor">#1976D2</Color>
    <Color x:Key="ButtonActiveColor">#1565C0</Color>
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="{StaticResource ButtonHoverColor}"/>
    <SolidColorBrush x:Key="ButtonActiveBrush" Color="{StaticResource ButtonActiveColor}"/>
    
    <!-- Overlay Colors / Màu Lớp phủ -->
    <SolidColorBrush x:Key="OverlayDark" Color="#000000" Opacity="0.5"/>
    <SolidColorBrush x:Key="OverlayLight" Color="#000000" Opacity="0.2"/>
    
    <!-- Enhanced Blue Gradients / Gradient Xanh Nâng cao -->
    <LinearGradientBrush x:Key="BlueGradientModern" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#2196F3" Offset="0"/>
        <GradientStop Color="#1976D2" Offset="0.5"/>
        <GradientStop Color="#1565C0" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- Animated Shimmer Gradient / Gradient Shimmer Động -->
    <LinearGradientBrush x:Key="ShimmerGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#F0F0F0" Offset="0"/>
        <GradientStop Color="#FAFAFA" Offset="0.5"/>
        <GradientStop Color="#F0F0F0" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- =========================================== -->
    <!-- Legacy Aliases (Backward Compatibility) -->
    <!-- Bí danh Cũ (Tương thích Ngược) -->
    <!-- =========================================== -->
    
    <SolidColorBrush x:Key="DarkBgBrush" Color="{StaticResource LightBgColor}"/>
    <SolidColorBrush x:Key="DarkSurfaceBrush" Color="{StaticResource WhiteColor}"/>
    <SolidColorBrush x:Key="DarkCardBrush" Color="{StaticResource CardBgColor}"/>
    <SolidColorBrush x:Key="DarkElevatedBrush" Color="{StaticResource WhiteColor}"/>
    <SolidColorBrush x:Key="DarkBorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="NavyHeaderBrush" Color="{StaticResource AccentBlueColor}"/>
    <SolidColorBrush x:Key="AccentTealBrush" Color="{StaticResource GreenColor}"/>
    <SolidColorBrush x:Key="AccentOrangeBrush" Color="{StaticResource OrangeButtonColor}"/>
    <SolidColorBrush x:Key="AccentYellowBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="AccentRedBrush" Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="AccentPurpleBrush" Color="#9C27B0"/>
    <SolidColorBrush x:Key="BorderHoverBrush" Color="{StaticResource BorderDarkColor}"/>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource AccentBlueColor}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource GreenColor}"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource LightBgColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource WhiteColor}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBgColor}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="NegativeBrush" Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="PositiveBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource GreenColor}"/>
    <SolidColorBrush x:Key="CriticalBrush" Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="SurfaceLightBrush" Color="{StaticResource WhiteColor}"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="BorderGlowBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="GoldTrophyBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="BrightBlueBrush" Color="{StaticResource AccentBlueColor}"/>
    <SolidColorBrush x:Key="LightBlueBrush" Color="{StaticResource AccentBlueLightColor}"/>
    <SolidColorBrush x:Key="CyanGlowBrush" Color="{StaticResource AccentBlueLightColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource ErrorColor}"/>

    <LinearGradientBrush x:Key="GoldGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#FF9800" Offset="0"/>
        <GradientStop Color="#FFC107" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="SuccessGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#4CAF50" Offset="0"/>
        <GradientStop Color="#66BB6A" Offset="1"/>
    </LinearGradientBrush>

</ResourceDictionary>
