<UserControl x:Class="AVASec.UI.Controls.NotificationCenter"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="350">
             
    <UserControl.Resources>
         <SolidColorBrush x:Key="PanelBackground" Color="#0F172A" Opacity="0.95"/>
         <SolidColorBrush x:Key="NeonCyan" Color="#06B6D4"/>
    </UserControl.Resources>

    <Border Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource NeonCyan}" BorderThickness="1,0,0,0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <Grid Grid.Row="0" Margin="20,0">
                <TextBlock Text="NOTIFICATIONS" Foreground="{StaticResource NeonCyan}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Left">
                     <TextBlock.Effect>
                        <DropShadowEffect Color="#06B6D4" BlurRadius="10" ShadowDepth="0"/>
                     </TextBlock.Effect>
                </TextBlock>
                <Button Content="Clear All" Click="ClearAll_Click" VerticalAlignment="Center" HorizontalAlignment="Right" Background="Transparent" Foreground="#94A3B8" BorderThickness="0" Cursor="Hand"/>
            </Grid>
            
            <!-- List -->
            <ListBox x:Name="NotificationList" Grid.Row="1" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                     <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="ItemBorder" Background="#1E293B" CornerRadius="8" Margin="10,5" Padding="10" BorderBrush="#334155" BorderThickness="1">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#334155"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                     </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Icon/Type Indicator -->
                            <!-- Ideally use Converter for color based on Type -->
                            <Ellipse Width="8" Height="8" Fill="{Binding Type, Converter={StaticResource NotificationColorConverter}}" VerticalAlignment="Top" Margin="0,5,10,0"/>

                            <StackPanel Grid.Column="1">
                                <Grid>
                                    <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="Bold" FontSize="13"/>
                                    <TextBlock Text="{Binding TimeAgo}" Foreground="#64748B" FontSize="10" HorizontalAlignment="Right"/>
                                </Grid>
                                <TextBlock Text="{Binding Message}" Foreground="#CBD5E1" FontSize="12" TextWrapping="Wrap" Margin="0,2,0,5"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Border>
</UserControl>
