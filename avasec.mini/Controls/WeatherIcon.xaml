<UserControl x:Class="AVASec.Mini.Controls.WeatherIcon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="44" Height="44" SnapsToDevicePixels="True" UseLayoutRounding="True">
    <Viewbox Stretch="Uniform" Width="44" Height="44">
        <Canvas Width="48" Height="48">

            <!-- Nắng / Sunny -->
            <Canvas x:Name="SunnyPanel" Visibility="Collapsed">
                <Ellipse Canvas.Left="14" Canvas.Top="14" Width="20" Height="20" Fill="#FBBF24"/>
                <Line X1="24" Y1="4" X2="24" Y2="10" Stroke="#F59E0B" StrokeThickness="2.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                <Line X1="24" Y1="38" X2="24" Y2="44" Stroke="#F59E0B" StrokeThickness="2.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                <Line X1="4" Y1="24" X2="10" Y2="24" Stroke="#F59E0B" StrokeThickness="2.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                <Line X1="38" Y1="24" X2="44" Y2="24" Stroke="#F59E0B" StrokeThickness="2.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                <Line X1="9.8" Y1="9.8" X2="14.2" Y2="14.2" Stroke="#F59E0B" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                <Line X1="33.8" Y1="33.8" X2="38.2" Y2="38.2" Stroke="#F59E0B" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                <Line X1="33.8" Y1="9.8" X2="38.2" Y2="14.2" Stroke="#F59E0B" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                <Line X1="9.8" Y1="33.8" X2="14.2" Y2="38.2" Stroke="#F59E0B" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
            </Canvas>

            <!-- Ít mây / Partly cloudy -->
            <Canvas x:Name="PartlyCloudyPanel" Visibility="Collapsed">
                <Ellipse Canvas.Left="22" Canvas.Top="6" Width="18" Height="18" Fill="#FBBF24"/>
                <Line X1="31" Y1="2" X2="31" Y2="6" Stroke="#F59E0B" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                <Line X1="38" Y1="12" X2="42" Y2="12" Stroke="#F59E0B" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                <Ellipse Canvas.Left="6" Canvas.Top="18" Width="22" Height="16" Fill="#9CA3AF"/>
                <Ellipse Canvas.Left="16" Canvas.Top="14" Width="26" Height="20" Fill="#B0B8C4"/>
                <Ellipse Canvas.Left="28" Canvas.Top="18" Width="18" Height="14" Fill="#9CA3AF"/>
            </Canvas>

            <!-- Nhiều mây / Cloudy -->
            <Canvas x:Name="CloudyPanel" Visibility="Collapsed">
                <Ellipse Canvas.Left="6" Canvas.Top="20" Width="24" Height="18" Fill="#9CA3AF"/>
                <Ellipse Canvas.Left="16" Canvas.Top="14" Width="28" Height="22" Fill="#B0B8C4"/>
                <Ellipse Canvas.Left="28" Canvas.Top="20" Width="20" Height="16" Fill="#9CA3AF"/>
            </Canvas>

            <!-- Sương mù / Fog -->
            <Canvas x:Name="FogPanel" Visibility="Collapsed">
                <Ellipse Canvas.Left="8" Canvas.Top="12" Width="32" Height="20" Fill="#CBD5E1" Opacity="0.9"/>
                <Rectangle Canvas.Left="6" Canvas.Top="26" Width="36" Height="3" RadiusX="1.5" RadiusY="1.5" Fill="#94A3B8"/>
                <Rectangle Canvas.Left="10" Canvas.Top="32" Width="28" Height="3" RadiusX="1.5" RadiusY="1.5" Fill="#94A3B8" Opacity="0.85"/>
                <Rectangle Canvas.Left="8" Canvas.Top="38" Width="32" Height="3" RadiusX="1.5" RadiusY="1.5" Fill="#94A3B8" Opacity="0.7"/>
            </Canvas>

            <!-- Mưa / Rain (mây xám + hạt mưa xanh) -->
            <Canvas x:Name="RainPanel" Visibility="Collapsed">
                <Ellipse Canvas.Left="6" Canvas.Top="10" Width="22" Height="16" Fill="#9CA3AF"/>
                <Ellipse Canvas.Left="14" Canvas.Top="6" Width="26" Height="20" Fill="#B0B8C4"/>
                <Ellipse Canvas.Left="26" Canvas.Top="10" Width="18" Height="14" Fill="#9CA3AF"/>
                <Line X1="14" Y1="28" X2="12" Y2="38" Stroke="#38BDF8" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                <Line X1="22" Y1="28" X2="20" Y2="40" Stroke="#2563EB" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                <Line X1="30" Y1="28" X2="28" Y2="38" Stroke="#38BDF8" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                <Line X1="18" Y1="30" X2="17" Y2="42" Stroke="#0EA5E9" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                <Line X1="26" Y1="30" X2="25" Y2="42" Stroke="#0EA5E9" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
            </Canvas>

            <!-- Mưa phùn / Drizzle -->
            <Canvas x:Name="DrizzlePanel" Visibility="Collapsed">
                <Ellipse Canvas.Left="8" Canvas.Top="12" Width="20" Height="14" Fill="#9CA3AF"/>
                <Ellipse Canvas.Left="16" Canvas.Top="8" Width="24" Height="18" Fill="#B0B8C4"/>
                <Ellipse Canvas.Left="28" Canvas.Top="12" Width="16" Height="12" Fill="#9CA3AF"/>
                <Ellipse Canvas.Left="16" Canvas.Top="28" Width="3" Height="5" Fill="#38BDF8"/>
                <Ellipse Canvas.Left="22" Canvas.Top="30" Width="3" Height="5" Fill="#2563EB"/>
                <Ellipse Canvas.Left="28" Canvas.Top="28" Width="3" Height="5" Fill="#38BDF8"/>
            </Canvas>

            <!-- Mưa rào / Showers -->
            <Canvas x:Name="ShowersPanel" Visibility="Collapsed">
                <Ellipse Canvas.Left="4" Canvas.Top="8" Width="20" Height="14" Fill="#9CA3AF"/>
                <Ellipse Canvas.Left="14" Canvas.Top="4" Width="24" Height="18" Fill="#B0B8C4"/>
                <Ellipse Canvas.Left="26" Canvas.Top="8" Width="18" Height="14" Fill="#9CA3AF"/>
                <Line X1="12" Y1="24" X2="10" Y2="34" Stroke="#38BDF8" StrokeThickness="2.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                <Line X1="20" Y1="22" X2="18" Y2="36" Stroke="#2563EB" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                <Line X1="28" Y1="24" X2="26" Y2="34" Stroke="#38BDF8" StrokeThickness="2.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                <Line X1="36" Y1="26" X2="34" Y2="38" Stroke="#0EA5E9" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
            </Canvas>

            <!-- Dông / Thunderstorm -->
            <Canvas x:Name="StormPanel" Visibility="Collapsed">
                <Ellipse Canvas.Left="6" Canvas.Top="6" Width="22" Height="16" Fill="#6B7280"/>
                <Ellipse Canvas.Left="14" Canvas.Top="2" Width="28" Height="20" Fill="#9CA3AF"/>
                <Ellipse Canvas.Left="28" Canvas.Top="6" Width="16" Height="12" Fill="#6B7280"/>
                <Line X1="14" Y1="24" X2="12" Y2="34" Stroke="#38BDF8" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                <Line X1="22" Y1="24" X2="20" Y2="36" Stroke="#2563EB" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                <Line X1="30" Y1="24" X2="28" Y2="34" Stroke="#38BDF8" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                <Path Fill="#FBBF24" Data="M26,22 L22,30 L25,30 L21,40 L29,28 L26,28 Z"/>
            </Canvas>

            <!-- Tuyết / Snow -->
            <Canvas x:Name="SnowPanel" Visibility="Collapsed">
                <Ellipse Canvas.Left="8" Canvas.Top="10" Width="22" Height="16" Fill="#9CA3AF"/>
                <Ellipse Canvas.Left="16" Canvas.Top="6" Width="26" Height="20" Fill="#B0B8C4"/>
                <Ellipse Canvas.Left="28" Canvas.Top="10" Width="16" Height="12" Fill="#9CA3AF"/>
                <Ellipse Canvas.Left="14" Canvas.Top="30" Width="4" Height="4" Fill="#E0F2FE"/>
                <Ellipse Canvas.Left="22" Canvas.Top="34" Width="4" Height="4" Fill="#FFFFFF"/>
                <Ellipse Canvas.Left="30" Canvas.Top="30" Width="4" Height="4" Fill="#E0F2FE"/>
            </Canvas>

            <!-- Ban đêm / Night -->
            <Canvas x:Name="NightPanel" Visibility="Collapsed">
                <Ellipse Canvas.Left="14" Canvas.Top="10" Width="22" Height="22" Fill="#E5E7EB"/>
                <Ellipse Canvas.Left="20" Canvas.Top="8" Width="20" Height="20" Fill="#374151"/>
                <Ellipse Canvas.Left="10" Canvas.Top="28" Width="6" Height="6" Fill="#FBBF24" Opacity="0.8"/>
                <Ellipse Canvas.Left="32" Canvas.Top="32" Width="4" Height="4" Fill="#FBBF24" Opacity="0.6"/>
            </Canvas>

            <!-- Mặc định / Fair -->
            <Canvas x:Name="FairPanel" Visibility="Visible">
                <Ellipse Canvas.Left="14" Canvas.Top="14" Width="20" Height="20" Fill="#FBBF24"/>
                <Ellipse Canvas.Left="22" Canvas.Top="20" Width="18" Height="12" Fill="#9CA3AF" Opacity="0.85"/>
            </Canvas>

        </Canvas>
    </Viewbox>
</UserControl>