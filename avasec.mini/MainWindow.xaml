<Window x:Class="AVASec.Mini.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:AVASec.Mini.Controls"
        Title="AVA Security Mini - Đèn thần / Genie Lamp"
        Width="400" Height="900"
        MinWidth="360" MinHeight="680"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="Manual"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        FontFamily="{StaticResource MiniFont}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="58" ResizeBorderThickness="6" GlassFrameThickness="0" CornerRadius="60,60,30,30"/>
    </WindowChrome.WindowChrome>

    <Grid ClipToBounds="False">
        <Border Background="{StaticResource MiniLampBodyBrush}"
                BorderBrush="{StaticResource MiniLampGoldBrush}" BorderThickness="4"
                CornerRadius="72,72,44,44"
                Effect="{StaticResource MiniLampGlow}"
                Margin="0,0,0,64">
            <Grid>
                <Grid IsHitTestVisible="False" Panel.ZIndex="2">
                    <Path Fill="{StaticResource MiniLampBronzeBrush}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-6,36,0,0"
                          Data="M 8,40 Q -10,24 4,8 Q 22,30 32,46 Z"/>
                    <Path Stroke="{StaticResource MiniLampBronzeBrush}" StrokeThickness="5" Fill="Transparent"
                          HorizontalAlignment="Right" VerticalAlignment="Stretch" Margin="0,70,2,120"
                          Data="M 0,0 Q 36,-28 32,120"/>
                    <Ellipse Height="16" VerticalAlignment="Top" Margin="90,6,90,0"
                             Fill="{StaticResource MiniLampShineBrush}" Opacity="0.55"/>
                </Grid>

                <Grid Margin="10,6,10,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="58"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="48"/>
                        <RowDefinition Height="20"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                        <Border Background="{StaticResource MiniLampHeaderGradient}" CornerRadius="58,58,0,0"/>
                        <Grid Margin="14,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🪔" FontSize="18" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="AVA Security Mini" FontSize="{DynamicResource MiniFontHeaderTitle}" FontWeight="SemiBold" Foreground="White"/>
                                    <Border Style="{StaticResource MiniFreeBadge}" Margin="8,0,0,0">
                                        <TextBlock Style="{StaticResource MiniFreeBadgeText}"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="Đèn thần may mắn / Lucky genie lamp" FontSize="{DynamicResource MiniFontHeaderSub}" Foreground="{StaticResource MiniLampHeaderSubBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,4,0,0">
                                <Button Style="{StaticResource MiniWin11CaptionButton}" Click="MinimizeButton_Click" ToolTip="Thu nhỏ / Minimize" WindowChrome.IsHitTestVisibleInChrome="True">
                                    <Path Data="M0,0 H10" Stroke="White" StrokeThickness="1" Width="10" Height="1" Stretch="None"/>
                                </Button>
                                <Button Style="{StaticResource MiniWin11CaptionButton}" Click="MaximizeButton_Click" ToolTip="Phóng to / Maximize" WindowChrome.IsHitTestVisibleInChrome="True">
                                    <Rectangle Width="10" Height="10" Stroke="White" StrokeThickness="1" Fill="Transparent"/>
                                </Button>
                                <Button Style="{StaticResource MiniWin11CaptionButton}" Click="TrayButton_Click" ToolTip="Ẩn khay / Hide to tray" WindowChrome.IsHitTestVisibleInChrome="True">
                                    <Path Data="M2,8 L8,2 M8,8 L2,2" Stroke="White" StrokeThickness="1" Width="10" Height="10" Stretch="Uniform"/>
                                </Button>
                                <Button Style="{StaticResource MiniWin11CloseButton}" Click="CloseButton_Click" ToolTip="Thoát / Exit" WindowChrome.IsHitTestVisibleInChrome="True">
                                    <Path Data="M2,2 L8,8 M8,2 L2,8" Stroke="White" StrokeThickness="1.2" Width="10" Height="10" Stretch="Uniform"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="{StaticResource MiniBgBrush}" Padding="14,12,14,8">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <Border Style="{StaticResource MiniWeatherCard}" Padding="14,12,12,12"/>
                                <Border Style="{StaticResource MiniAccentStripe}" Background="{StaticResource MiniAccentBrush}"/>
                                <Grid Margin="14,12,12,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <controls:WeatherIcon x:Name="WeatherIcon" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="THỜI TIẾT / WEATHER" Style="{StaticResource MiniCardLabel}"/>
                                        <TextBlock x:Name="WeatherLineText" Text="Đang tải... / Loading..." FontSize="{DynamicResource MiniFontBody}" Foreground="{StaticResource MiniTextBrush}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                        <TextBlock x:Name="WeatherSubText" Text="" FontSize="{DynamicResource MiniFontBodySmall}" Foreground="{StaticResource MiniMutedBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                            <Grid Margin="0,0,0,10">
                                <Border Style="{StaticResource MiniQuoteCard}" Padding="14,12,12,12"/>
                                <Border Style="{StaticResource MiniAccentStripe}" Background="{StaticResource MiniWarmBrush}"/>
                                <StackPanel Margin="14,12,12,12">
                                    <TextBlock Text="HÔM NAY / TODAY" Style="{StaticResource MiniCardLabel}"/>
                                    <TextBlock x:Name="QuoteText" Text="Đang tải... / Loading..." FontSize="{DynamicResource MiniFontBody}" Foreground="{StaticResource MiniTextBrush}" Margin="0,8,0,0" TextWrapping="Wrap" LineHeight="{DynamicResource MiniFontLineHeightBody}"/>
                                    <TextBlock x:Name="QuoteAuthorText" Text="" FontSize="{DynamicResource MiniFontBodySmall}" Foreground="{StaticResource MiniMutedBrush}" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Grid>
                            <Border Style="{StaticResource MiniInfoBar}" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="LỊCH / CALENDAR" Style="{StaticResource MiniCardLabel}"/>
                                    <TextBlock x:Name="SolarDateText" FontSize="{DynamicResource MiniFontBody}" Foreground="{StaticResource MiniTextBrush}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                    <TextBlock x:Name="LunarDateText" FontSize="{DynamicResource MiniFontBodySmall}" Foreground="{StaticResource MiniMutedBrush}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                    <TextBlock x:Name="CanChiText" FontSize="{DynamicResource MiniFontCaption}" Foreground="{StaticResource MiniMutedBrush}" Margin="0,2,0,0"/>
                                    <TextBlock x:Name="FestivalText" FontSize="{DynamicResource MiniFontCaption}" Foreground="{StaticResource MiniAccentBrush}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/><ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="*"/><ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource MiniMetricCard}">
                                    <StackPanel>
                                        <TextBlock Text="CPU" Style="{StaticResource MiniCardLabel}"/>
                                        <TextBlock x:Name="CpuText" Text="--" FontSize="{DynamicResource MiniFontMetric}" FontWeight="SemiBold" Foreground="{StaticResource MiniTextBrush}" Margin="0,6,0,2"/>
                                        <TextBlock x:Name="CpuSubText" Text="..." FontSize="{DynamicResource MiniFontCaption}" Foreground="{StaticResource MiniMutedBrush}" Margin="0,0,0,8"/>
                                        <ProgressBar x:Name="CpuBar" Style="{StaticResource MiniProgressBar}"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Style="{StaticResource MiniMetricCard}">
                                    <StackPanel>
                                        <TextBlock Text="RAM" Style="{StaticResource MiniCardLabel}"/>
                                        <TextBlock x:Name="RamPercentText" Text="--" FontSize="{DynamicResource MiniFontMetric}" FontWeight="SemiBold" Foreground="{StaticResource MiniTextBrush}" Margin="0,6,0,2"/>
                                        <TextBlock x:Name="RamText" Text="--" FontSize="{DynamicResource MiniFontCaption}" Foreground="{StaticResource MiniMutedBrush}" Margin="0,0,0,8"/>
                                        <ProgressBar x:Name="RamBar" Style="{StaticResource MiniProgressBar}"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="4" Style="{StaticResource MiniMetricCard}">
                                    <StackPanel>
                                        <TextBlock Text="DISK" Style="{StaticResource MiniCardLabel}"/>
                                        <TextBlock x:Name="DiskPercentText" Text="--" FontSize="{DynamicResource MiniFontMetric}" FontWeight="SemiBold" Foreground="{StaticResource MiniTextBrush}" Margin="0,6,0,2"/>
                                        <TextBlock x:Name="DiskText" Text="--" FontSize="{DynamicResource MiniFontCaption}" Foreground="{StaticResource MiniMutedBrush}" Margin="0,0,0,8"/>
                                        <ProgressBar x:Name="DiskBar" Style="{StaticResource MiniProgressBar}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <Border Style="{StaticResource MiniInfoBar}" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="GỢI Ý / TIP" Style="{StaticResource MiniCardLabel}"/>
                                    <TextBlock x:Name="TipText" Text="..." FontSize="{DynamicResource MiniFontBodySmall}" Foreground="{StaticResource MiniTextBrush}" Margin="0,8,0,0" TextWrapping="Wrap" LineHeight="{DynamicResource MiniFontLineHeightBody}"/>
                                </StackPanel>
                            </Border>
                            <UniformGrid Columns="2" Margin="0,0,0,10">
                                <Button x:Name="BoostButton" Style="{StaticResource MiniPrimaryButton}" Margin="0,0,4,0" Click="BoostButton_Click" ToolTip="Tăng tốc / Boost">
                                    <TextBlock Text="Tăng tốc / Boost" FontSize="{DynamicResource MiniFontButton}"/>
                                </Button>
                                <Button x:Name="CleanButton" Style="{StaticResource MiniSecondaryButton}" Margin="4,0,0,0" Click="CleanButton_Click" ToolTip="Dọn rác / Clean">
                                    <TextBlock Text="Dọn rác / Clean" FontSize="{DynamicResource MiniFontButton}"/>
                                </Button>
                            </UniformGrid>
                            <ProgressBar x:Name="ActionProgress" Style="{StaticResource MiniProgressBar}" Height="4" Margin="0,0,0,10" Visibility="Collapsed" IsIndeterminate="True"/>
                            <TextBlock Text="NHẬT KÝ / LOG" Style="{StaticResource MiniCardLabel}" Margin="0,0,0,6"/>
                            <Border Style="{StaticResource MiniSurfaceCard}" Padding="10,8" MinHeight="70">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="92">
                                    <TextBlock x:Name="LogText" FontSize="{DynamicResource MiniFontLog}" Foreground="{StaticResource MiniMutedBrush}" TextWrapping="Wrap" LineHeight="{DynamicResource MiniFontLineHeightLog}"/>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="2" Background="{StaticResource MiniFooterBrush}" BorderBrush="{StaticResource MiniBorderBrush}" BorderThickness="0,1,0,0" Padding="12,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox x:Name="AlwaysOnTopCheck" Grid.Column="0" Content="Luôn trên cùng / Always on top" Style="{StaticResource MiniWin11CheckBox}" VerticalAlignment="Center" Checked="AlwaysOnTopCheck_Changed" Unchecked="AlwaysOnTopCheck_Changed"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0,6,0">
                                <TextBlock Text="Cỡ chữ / Font" FontSize="{DynamicResource MiniFontCaption}" Foreground="{StaticResource MiniMutedBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <Button x:Name="FontDecreaseButton" Style="{StaticResource MiniFontScaleButton}" Content="A-" Click="FontDecreaseButton_Click" ToolTip="Giảm cỡ chữ / Smaller"/>
                                <TextBlock x:Name="FontScaleLabel" Text="115%" Width="40" TextAlignment="Center" FontSize="{DynamicResource MiniFontCaption}" FontWeight="SemiBold" Foreground="{StaticResource MiniTextBrush}" VerticalAlignment="Center" Margin="2,0"/>
                                <Button x:Name="FontIncreaseButton" Style="{StaticResource MiniFontScaleButton}" Content="A+" Click="FontIncreaseButton_Click" ToolTip="Tăng cỡ chữ / Larger"/>
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="v1.0" FontSize="{DynamicResource MiniFontCaption}" Foreground="{StaticResource MiniMutedBrush}" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="3" VerticalAlignment="Bottom">
                        <Ellipse Height="16" Width="130" Fill="{StaticResource MiniLampBronzeBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Ellipse Height="10" Width="90" Fill="{StaticResource MiniLampGoldBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,2,0,0"/>
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <controls:SmokeEffect VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,-8"/>
    </Grid>
</Window>