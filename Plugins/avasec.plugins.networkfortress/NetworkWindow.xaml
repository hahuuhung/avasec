<Window x:Class="AVASec.Plugins.NetworkFortress.NetworkWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Network Fortress" Height="450" Width="700"
        WindowStartupLocation="CenterScreen"
        Background="#001F33" Foreground="#00CCFF">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" BorderBrush="#005580" BorderThickness="0,0,0,1" Padding="0,0,0,15" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🛡️" FontSize="24" Margin="0,0,15,0"/>
                <StackPanel>
                    <TextBlock Text="NETWORK FORTRESS" FontSize="20" FontWeight="Bold" Foreground="#00CCFF"/>
                    <TextBlock Text="Active Traffic Monitor" FontSize="12" Foreground="#007ACC"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Graph Area -->
        <Grid Grid.Row="1">
            <Border BorderBrush="#005580" BorderThickness="1" Background="#00101A" CornerRadius="4">
                <Canvas x:Name="GraphCanvas" ClipToBounds="True"/>
            </Border>
            
            <!-- Stats Overlay -->
            <StackPanel VerticalAlignment="Top" HorizontalAlignment="Right" Margin="20" Background="#AA000000">
                <TextBlock Text="DOWNLOAD" FontSize="10" Foreground="#888"/>
                <TextBlock x:Name="DownloadText" Text="0 KB/s" FontSize="24" FontWeight="Bold" Foreground="#00FF00"/>
                <TextBlock Text="UPLOAD" FontSize="10" Foreground="#888" Margin="0,10,0,0"/>
                <TextBlock x:Name="UploadText" Text="0 KB/s" FontSize="24" FontWeight="Bold" Foreground="#FFCC00"/>
            </StackPanel>
        </Grid>

        <!-- Footer -->
        <Grid Grid.Row="2" Margin="0,15,0,0">
            <TextBlock x:Name="InterfaceText" Text="Monitoring: Ethernet" VerticalAlignment="Center" Foreground="#007ACC"/>
            <Button Content="STOP MONITOR" Padding="15,8" HorizontalAlignment="Right" Background="#00334D" Foreground="White" BorderBrush="#00CCFF" BorderThickness="1" Click="Toggle_Click"/>
        </Grid>
    </Grid>
</Window>
