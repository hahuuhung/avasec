<Window x:Class="AVASec.Plugins.GameBooster.BoosterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Game Booster Ultra" Height="500" Width="400"
        WindowStartupLocation="CenterScreen"
        Background="#0F0F0F" Foreground="White"
        ResizeMode="NoResize" WindowStyle="None" AllowsTransparency="True">
    
    <Window.Resources>
        <Style TargetType="Button" x:Key="BoostButtonStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="4"/>
            <Setter Property="BorderBrush" Value="#FF3333"/>
            <Setter Property="Foreground" Value="#FF3333"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse Stroke="{TemplateBinding BorderBrush}" StrokeThickness="{TemplateBinding BorderThickness}" Fill="{TemplateBinding Background}"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#33FF3333"/>
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#FF3333" BlurRadius="20" ShadowDepth="0"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="16" BorderBrush="#333" BorderThickness="1" Background="#0F0F0F">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="20">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🎮" FontSize="20" Margin="0,0,10,0"/>
                    <TextBlock Text="GAME BOOSTER ULTRA" FontWeight="Bold" FontSize="16" Foreground="#FF3333"/>
                </StackPanel>
                <Button Content="✕" HorizontalAlignment="Right" Click="Close_Click" Background="Transparent" Foreground="#666" BorderThickness="0"/>
            </Grid>

            <!-- Main Content -->
            <Grid Grid.Row="1" VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center">
                    <!-- Boost Circle -->
                    <Button x:Name="BoostBtn" Width="180" Height="180" Click="Boost_Click" Style="{StaticResource BoostButtonStyle}">
                        <StackPanel>
                            <TextBlock Text="BOOST" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="StatusText" Text="READY" FontSize="14" Foreground="#999" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <!-- Stats -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,30,0,0">
                        <Border Background="#222" CornerRadius="8" Padding="15,10" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="RAM Freed" FontSize="12" Foreground="#666"/>
                                <TextBlock x:Name="RamText" Text="0 MB" FontSize="18" FontWeight="Bold" Foreground="#44FF44"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#222" CornerRadius="8" Padding="15,10">
                            <StackPanel>
                                <TextBlock Text="Processes" FontSize="12" Foreground="#666"/>
                                <TextBlock x:Name="ProcText" Text="0 Stopped" FontSize="18" FontWeight="Bold" Foreground="#FFFF44"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- Footer -->
            <TextBlock Grid.Row="2" Text="AVA Security Performance Core v2026" Foreground="#333" HorizontalAlignment="Center" Margin="10" FontSize="10"/>
        </Grid>
    </Border>
</Window>
